<controls:ContentPopup x:Class="Telegram.Controls.Stories.Popups.StoryReactPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:cells="using:Telegram.Controls.Cells"
                       xmlns:local="using:Telegram.Controls.Stories.Popups"
                       mc:Ignorable="d"
                       Padding="0"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Button x:Name="Alias"
                Click="Alias_Click"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Style="{StaticResource ListEmptyButtonStyle}"
                CornerRadius="14"
                Margin="8">
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:ProfilePicture x:Name="Photo"
                                         Size="28" />

                <Grid Width="20"
                      Height="20"
                      Margin="4,0,8,0"
                      Grid.Column="2">

                    <TextBlock Text="&#xE0E4;"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Grid.Column="2" />
                    <TextBlock Text="&#xE0E5;"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Grid.Column="2" />
                </Grid>
            </Grid>
        </Button>

        <StackPanel Grid.Row="1">
            <controls:PremiumSlider x:Name="StarCountSlider"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    IsThumbToolTipEnabled="False"
                                    Glyph="&#xEA87;"
                                    ValueChanged="StarCountSlider_ValueChanged"
                                    Minimum="0"
                                    Maximum="1000"
                                    Margin="24,0,24,12" />

            <Grid x:Name="LevelRoot"
                  Margin="8,0,8,16"
                  ColumnSpacing="8"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid Background="{ThemeResource SettingsItemBackground}"
                      CornerRadius="8"
                      Padding="8,4,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:AnimatedTextBlock x:Name="Duration"
                                                TextStyle="{StaticResource SubtitleTextBlockStyle}"
                                                TextAlignment="Center"
                                                HorizontalAlignment="Center" />
                    <TextBlock Text="{CustomResource LiveStoryHighlightFeaturePin}"
                               TextAlignment="Center"
                               Grid.Row="1" />
                </Grid>
                <Grid Background="{ThemeResource SettingsItemBackground}"
                      CornerRadius="8"
                      Padding="8,4,8,8"
                      Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:AnimatedTextBlock x:Name="Length"
                                                TextStyle="{StaticResource SubtitleTextBlockStyle}"
                                                TextAlignment="Center"
                                                HorizontalAlignment="Center" />
                    <TextBlock Text="{CustomResource LiveStoryHighlightFeatureLength}"
                               TextAlignment="Center"
                               Grid.Row="1" />
                </Grid>
                <Grid Background="{ThemeResource SettingsItemBackground}"
                      CornerRadius="8"
                      Padding="8,4,8,8"
                      Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:AnimatedTextBlock x:Name="Emoji"
                                                TextStyle="{StaticResource SubtitleTextBlockStyle}"
                                                TextAlignment="Center"
                                                HorizontalAlignment="Center" />
                    <TextBlock Text="{CustomResource LiveStoryHighlightFeatureEmoji}"
                               TextAlignment="Center"
                               Grid.Row="1" />
                </Grid>
            </Grid>

            <TextBlock x:Name="Subtitle"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="12,0,12,12" />

            <StackPanel x:Name="TopReactorsRoot"
                        Margin="0,12,0,0">
                <local:PaidReactorsPanel x:Name="TopReactors">
                    <local:PaidReactorsPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </local:PaidReactorsPanel.ChildrenTransitions>
                </local:PaidReactorsPanel>
            </StackPanel>

            <Border BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Margin="24,12,24,0"
                    VerticalAlignment="Center" />

            <cells:LiveStoryMessageCell x:Name="Preview"
                                        HorizontalAlignment="Center"
                                        Margin="0,14,0,14" />
        </StackPanel>

        <Button x:Name="PurchaseCommand"
                Click="Purchase_Click"
                Style="{StaticResource AccentButtonStyle}"
                FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Margin="24,0,24,16"
                Grid.Row="2">
            <Grid>
                <TextBlock x:Name="PurchaseText"
                           VerticalAlignment="Center" />
                <muxc:ProgressRing x:Name="PurchaseRing"
                                   Visibility="Collapsed"
                                   Foreground="#FFFFFF"
                                   Width="20"
                                   Height="20" />
            </Grid>
        </Button>

        <controls:SettingsFooter IsLink="True"
                                 Click="SettingsFooter_Click"
                                 Text="{CustomResource StarsReactionTerms}"
                                 TextAlignment="Center"
                                 Margin="12,0,12,24"
                                 Grid.Row="3" />
    </Grid>
</controls:ContentPopup>
