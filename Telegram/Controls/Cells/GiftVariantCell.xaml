<UserControl x:Class="Telegram.Controls.Cells.GiftVariantCell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Telegram.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto"
                           MinHeight="4" />
        </Grid.RowDefinitions>
        <Border Background="{ThemeResource SettingsItemBackground}"
                BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Grid.RowSpan="2" />
        <controls:PatternBackground x:Name="Pattern"
                                    BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Grid.RowSpan="2">
            <Border Width="80" />
        </controls:PatternBackground>

        <controls:AnimatedImage x:Name="Animated"
                                ReplacementColor="#FFFFFF"
                                Width="80"
                                Height="80"
                                FrameSize="80,80"
                                DecodeFrameType="Logical"
                                AutoPlay="False"
                                IsViewportAware="True"
                                LoopCount="1"
                                Margin="4,12,4,4"
                                VerticalAlignment="Top" />

        <TextBlock x:Name="Title"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,8"
                   Grid.Row="1" />

        <controls:BadgeControl x:Name="Rarity"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Margin="4" />
    </Grid>
</UserControl>
