<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:controls="using:Telegram.Controls"
                    xmlns:local="using:Telegram.Controls.Cells"
                    mc:Ignorable="d"
                    d:DesignHeight="300"
                    d:DesignWidth="400">

    <Style TargetType="local:SharedMediaCell">
        <Setter Property="MinWidth"
                Value="{ThemeResource TelegramMediaMinWidth}" />
        <Setter Property="MinHeight"
                Value="{ThemeResource TelegramMediaMinHeight}" />
        <Setter Property="MaxWidth"
                Value="{ThemeResource TelegramMediaMaxWidth}" />
        <Setter Property="MaxHeight"
                Value="{ThemeResource TelegramMediaMaxHeight}" />
        <Setter Property="IsTabStop"
                Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SharedMediaCell">
                    <Grid Background="{ThemeResource SettingsItemBackground}">
                        <Border>
                            <Border.Background>
                                <ImageBrush x:Name="ThumbnailTexture"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>

                        <!--<controls:BadgeControl Text="00:08"
                                               Background="{ThemeResource MessageOverlayBackgroundBrush}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Bottom"
                                               Margin="4" />-->

                        <controls:AnimatedImage x:Name="Particles"
                                                IsViewportAware="True"
                                                FrameSize="0,0"
                                                FitToSize="True"
                                                DecodeFrameType="Logical"
                                                Stretch="UniformToFill" />

                        <Border x:Name="Overlay"
                                Background="{ThemeResource MessageOverlayBackgroundBrush}"
                                CornerRadius="{ThemeResource MessageOverlayCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Padding="6,1,6,3"
                                Margin="4">
                            <TextBlock x:Name="Subtitle"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="White"
                                       TextAlignment="Right"
                                       TextWrapping="NoWrap"
                                       Typography.NumeralAlignment="Tabular" />
                        </Border>

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>