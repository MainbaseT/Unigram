<UserControl x:Class="Telegram.Controls.Views.SearchChatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Telegram.Controls"
             xmlns:cells="using:Telegram.Controls.Cells"
             xmlns:selectors="using:Telegram.Selectors"
             xmlns:viewModels="using:Telegram.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <UserControl.Resources>
        <Style x:Key="HeaderListViewItemStyle"
               TargetType="ListViewItem">
            <Setter Property="MinHeight"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="HeaderTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource BaseTextBlockStyle}"
                           FontFamily="{StaticResource EmojiThemeFontFamily}"
                           Margin="12,12,0,4" />

                <controls:GlyphButton Click="ClearRecentChats_Click"
                                      AllowFocusOnInteraction="False"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,0,-6"
                                      Glyph="&#xE711;"
                                      FontSize="12"
                                      Width="48"
                                      Height="32"
                                      Grid.Column="1" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Name="ProfileTemplate">
            <cells:ProfileCell />
        </DataTemplate>

        <DataTemplate x:Name="MessageTemplate">
            <cells:ChatCell Stroke="{ThemeResource ChatLastMessageStateBrush}"
                            SelectionStroke="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                            Margin="4,0" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="DialogsSearchPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <!-- TODO: Hide in forward popup -->
        <controls:TopNavView x:Name="ChatFolders"
                             ItemsSource="{x:Bind ViewModel.Tabs}"
                             SelectedIndex="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                             SelectionChanged="ChatFolders_SelectionChanged"
                             ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                             FocusFollowsSingleSelection="True"
                             SingleSelectionFollowsFocus="False"
                             Height="40"
                             BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                             BorderThickness="0,0,0,0">
            <controls:TopNavView.ItemTemplate>
                <DataTemplate  x:DataType="viewModels:SearchChatsTabItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Text}" />
                        <controls:BadgeControl x:Name="Badge"
                                               x:Load="{x:Bind IsNew}"
                                               Text="NEW"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,0"
                                               CornerRadius="4"
                                               Grid.Column="1" />
                    </Grid>
                </DataTemplate>
            </controls:TopNavView.ItemTemplate>
        </controls:TopNavView>

        <!--<ListView x:Load="False"
                                          x:Name="PippoFranco"
                                          SelectionMode="None"
                                          IsItemClickEnabled="True"
                                          ItemClick="SearchFilters_ItemClick"
                                          ContainerContentChanging="SearchFilters_ContainerContentChanging"
                                          ItemsSource="{x:Bind ViewModel.Chats.Search.Filters, Mode=OneWay}"
                                          Style="{StaticResource HorizontalListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
