<local:ProfileTabPage x:Class="Telegram.Views.Profile.SearchPostsTabPage"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:controls="using:Telegram.Controls"
                      xmlns:cells="using:Telegram.Controls.Cells"
                      xmlns:local="using:Telegram.Views.Profile"
                      mc:Ignorable="d"
                      ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">

    <Grid>
        <ListView x:Name="ScrollingHost"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  ChoosingItemContainer="OnChoosingItemContainer"
                  ContainerContentChanging="OnContainerContentChanging">
            <ListView.Template>
                <ControlTemplate TargetType="ListView">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ItemsPresenter Header="{TemplateBinding Header}"
                                        HeaderTemplate="{TemplateBinding HeaderTemplate}"
                                        HeaderTransitions="{TemplateBinding HeaderTransitions}"
                                        Footer="{TemplateBinding Footer}"
                                        FooterTemplate="{TemplateBinding FooterTemplate}"
                                        FooterTransitions="{TemplateBinding FooterTransitions}"
                                        Padding="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </ListView.Template>
            <ListView.Header>
                <StackPanel>
                    <Border x:Name="Header" />
                </StackPanel>
            </ListView.Header>
            <ListView.Footer>
                <Border Height="60" />
            </ListView.Footer>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem"
                       BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="Margin"
                            Value="0,0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemContainerTransitions>
                <TransitionCollection />
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <cells:ChatCell Stroke="{ThemeResource ChatLastMessageStateBrush}"
                                    SelectionStroke="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                    Margin="4,0" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid x:Name="InitialState"
              VerticalAlignment="Center"
              Margin="12,-96,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="Title"
                       Text="{CustomResource SearchPostsTitle}"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,0,0,8" />

            <TextBlock x:Name="Subtitle"
                       Text="{CustomResource SearchPostsText}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       Grid.Row="1" />

            <Button x:Name="ActionButton"
                    Click="{x:Bind ViewModel.Search}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,0"
                    Width="200"
                    Grid.Row="2">
                <Grid Padding="4">
                    <TextBlock x:Name="PremiumButton"
                               Text="{CustomResource SearchPostsButtonPremium}"
                               TextAlignment="Center" />
                    <Grid x:Name="SearchButton"
                          HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="20"
                                   Margin="-2,0,4,-2" />
                        <TextBlock Text="{CustomResource SearchPostsButton}"
                                   Grid.Column="1" />
                        <TextBlock Text="{x:Bind ViewModel.QueryString, Mode=OneWay}"
                                   Margin="4,0,0,0"
                                   Opacity="0.6"
                                   Grid.Column="2" />
                        <TextBlock Text="&#xeab9;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="12"
                                   Margin="4,4,-2,-4"
                                   Grid.Column="3" />
                    </Grid>
                    <TextBlock x:Name="PaidButton"
                               TextAlignment="Center"
                               FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}" />
                </Grid>
            </Button>

            <TextBlock x:Name="PremiumInfo"
                       Text="{CustomResource SearchPostsPremium}"
                       Style="{StaticResource InfoCaptionTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="0,8,0,0"
                       Grid.Row="3" />

            <TextBlock x:Name="SearchInfo"
                       Text="{CustomResource SearchPostsPremium}"
                       Style="{StaticResource InfoCaptionTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="0,8,0,0"
                       Grid.Row="3" />
        </Grid>

        <Grid x:Name="NotFoundState"
              x:Load="False"
              VerticalAlignment="Center"
              Margin="0,-96,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <controls:AnimatedImage Source="ms-appx:///Assets/Animations/EmptyContacts.tgs"
                                    IsCachingEnabled="False"
                                    AutoPlay="True"
                                    FrameSize="140,140"
                                    DecodeFrameType="Logical"
                                    LoopCount="1"
                                    Width="140"
                                    Height="140"
                                    Margin="0,0,0,12" />

            <TextBlock Text="{CustomResource SearchPostsNotFound}"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,0,0,8"
                       Grid.Row="1" />

            <TextBlock Loaded="EmptyState_Loaded"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       Grid.Row="2" />
        </Grid>

        <Border x:Name="LoadingState"
                x:Load="False"
                Loaded="LoadingState_Loaded" />
    </Grid>
</local:ProfileTabPage>
