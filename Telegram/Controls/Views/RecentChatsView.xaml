<UserControl x:Class="Telegram.Controls.Views.RecentChatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Telegram.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <Grid Background="Transparent">
        <Grid x:Name="ShadowReceiver" />
        <Grid x:Name="RootGrid"
              BackgroundSizing="OuterBorderEdge"
              Background="{ThemeResource MenuFlyoutPresenterBackground}"
              BorderBrush="{ThemeResource MenuFlyoutPresenterBorderBrush}"
              BorderThickness="{ThemeResource MenuFlyoutPresenterBorderThemeThickness}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="24"
              CornerRadius="{ThemeResource OverlayCornerRadius}">
            <GridView x:Name="ScrollingHost"
                      ChoosingItemContainer="OnChoosingItemContainer"
                      ContainerContentChanging="OnContainerContentChanging"
                      ItemClick="OnItemClick"
                      IsItemClickEnabled="True"
                      SingleSelectionFollowsFocus="True"
                      Padding="7">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="80">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <controls:ProfilePicture Size="56"
                                                     Margin="12,8,12,4" />
                            <TextBlock TextAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       TextTrimming="WordEllipsis"
                                       FontSize="12"
                                       MaxLines="1"
                                       Margin="0,0,0,4"
                                       Grid.Row="1" />
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</UserControl>
