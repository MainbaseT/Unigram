<ToggleButton x:Class="Telegram.Controls.PollOptionControl"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
              Style="{StaticResource PollOptionButtonStyle}"
              mc:Ignorable="d"
              d:DesignHeight="300"
              d:DesignWidth="400">

    <UserControl x:Name="LayoutRoot">
        <Grid Padding="10,0">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="ResultState">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Correct">
                        <VisualState.Setters>
                            <Setter Target="TickFill.Foreground"
                                    Value="{ThemeResource MessagePollCorrectBrush}" />
                            <Setter Target="Zero.Fill"
                                    Value="{ThemeResource MessagePollCorrectBrush}" />
                            <Setter Target="Votes.Foreground"
                                    Value="{ThemeResource MessagePollCorrectBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Wrong">
                        <VisualState.Setters>
                            <Setter Target="TickGlyph.Glyph"
                                    Value="&#xF13D;" />
                            <Setter Target="TickFill.Foreground"
                                    Value="{ThemeResource MessagePollWrongBrush}" />
                            <Setter Target="Zero.Fill"
                                    Value="{ThemeResource MessagePollWrongBrush}" />
                            <Setter Target="Votes.Foreground"
                                    Value="{ThemeResource MessagePollWrongBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>
            <Ellipse x:Name="Ellipse"
                     Width="20"
                     Height="20"
                     UseLayoutRounding="False"
                     Stroke="{ThemeResource MessageHeaderBorderBrush}"
                     StrokeThickness="1.5"
                     VerticalAlignment="Top"
                     Margin="0,8,8,8" />
            <Grid Visibility="{x:Bind ConvertCheckMark(IsChecked), Mode=OneWay}"
                  Width="20"
                  Height="20"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="0,8,8,8">
                <Ellipse x:Name="CheckmarkCircle"
                         Width="20"
                         Height="20"
                         UseLayoutRounding="False"
                         Fill="{ThemeResource MessageHeaderBorderBrush}"
                         StrokeThickness="0"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <Path x:Name="Checkmark"
                      Fill="#FFFFFF"
                      Data="M13.2197 6.96967L8.75 11.4393L6.78033 9.4697C6.48744 9.1768 6.01256 9.1768 5.71967 9.4697C5.42678 9.7626 5.42678 10.2374 5.71967 10.5303L8.2197 13.0303C8.5126 13.3232 8.9874 13.3232 9.2803 13.0303L14.2803 8.0303C14.5732 7.73744 14.5732 7.26256 14.2803 6.96967C13.9874 6.67678 13.5126 6.67678 13.2197 6.96967Z" />
            </Grid>


            <muxc:ProgressRing x:Name="Loading"
                               MinWidth="20"
                               MinHeight="20"
                               Width="20"
                               Height="20"
                               UseLayoutRounding="False"
                               Foreground="{ThemeResource MessageHeaderBorderBrush}"
                               VerticalAlignment="Top"
                               Margin="0,8,8,8" />

            <TextBlock x:Name="Percentage"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold"
                       TextWrapping="NoWrap"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right"
                       Margin="-10,10,6,8" />

            <RichTextBlock x:Name="TextText"
                           Style="{StaticResource BodyRichTextBlockStyle}"
                           FontFamily="{ThemeResource EmojiThemeFontFamily}"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           VerticalAlignment="Top"
                           IsTextSelectionEnabled="False"
                           Margin="0,8,0,8"
                           Grid.Column="1">
                <Paragraph x:Name="Text" />
            </RichTextBlock>

            <Grid x:Name="Tick"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Right"
                  Width="12"
                  Height="12"
                  Margin="0,-8,6,-4"
                  Grid.Column="0"
                  Grid.Row="1">
                <FontIcon x:Name="TickFill"
                          Glyph="&#xF136;"
                          FontSize="12"
                          Foreground="{ThemeResource MessageHeaderBorderBrush}" />
                <FontIcon x:Name="TickGlyph"
                          Glyph="&#xF13E;"
                          FontSize="12"
                          Foreground="White" />
            </Grid>

            <Ellipse x:Name="Zero"
                     Fill="{ThemeResource MessageHeaderBorderBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Left"
                     Width="4"
                     Height="4"
                     Margin="0,-4,0,0"
                     Grid.Column="1"
                     Grid.Row="1" />

            <ProgressBar x:Name="Votes"
                         Foreground="{ThemeResource MessageHeaderBorderBrush}"
                         Style="{StaticResource PollOptionProgressBarStyle}"
                         Background="Transparent"
                         Margin="0,-4,0,0"
                         VerticalAlignment="Top"
                         Grid.Row="1"
                         Grid.Column="1" />

            <Border x:Name="VotesLine"
                    BorderBrush="{ThemeResource MessageSubtleForegroundBrush}"
                    BorderThickness="0,0,0,0.5"
                    VerticalAlignment="Bottom"
                    Margin="0,0,-10,0"
                    Opacity="0.3"
                    Grid.Column="1" />
        </Grid>
    </UserControl>
</ToggleButton>
