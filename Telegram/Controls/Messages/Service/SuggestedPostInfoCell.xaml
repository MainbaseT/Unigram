<Grid x:Class="Telegram.Controls.Messages.Service.SuggestedPostInfoCell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Telegram.Controls.Messages.Service"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="300"
      d:DesignWidth="400"
      Background="{ThemeResource MessageServiceBackgroundBrush}"
      CornerRadius="{ThemeResource MessageServiceCornerRadius}"
      Padding="12,6,12,8"
      Margin="0,4,0,0"
      MaxWidth="274">

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
    </Grid.RowDefinitions>
    <TextBlock x:Name="Title"
               Foreground="#FFFFFF"
               Style="{StaticResource CaptionTextBlockStyle}"
               TextAlignment="Center" />
    <Grid HorizontalAlignment="Center"
          Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PriceTitle"
                   Text="{CustomResource SuggestionOfferInfoPrice}"
                   Foreground="#AAFFFFFF"
                   Margin="0,4,0,0"
                   Style="{StaticResource CaptionTextBlockStyle}" />
        <TextBlock x:Name="Price"
                   Foreground="#FFFFFF"
                   FontWeight="SemiBold"
                   Margin="12,4,0,0"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Grid.Column="1" />

        <TextBlock x:Name="TimeTitle"
                   Text="{CustomResource SuggestionOfferInfoTime}"
                   Foreground="#AAFFFFFF"
                   Margin="0,4,0,0"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Grid.Row="1" />
        <TextBlock x:Name="Time"
                   Foreground="#FFFFFF"
                   FontWeight="SemiBold"
                   Margin="12,4,0,0"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Grid.Row="1"
                   Grid.Column="1" />
    </Grid>
</Grid>
