<UserControl x:Class="Telegram.Controls.ProfileHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Telegram.Controls"
             xmlns:cells="using:Telegram.Controls.Cells"
             mc:Ignorable="d"
             Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <UserControl.Resources>
        <Style x:Key="HeaderRootStyle"
               TargetType="Grid">
            <Setter Property="Background"
                    Value="{ThemeResource SettingsItemBackground}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border x:Name="ClipperBackground"
                Background="{ThemeResource PageSubHeaderBackgroundBrush2}"
                BorderBrush="{ThemeResource NavigationViewContentGridBorderBrush}"
                BorderThickness="0,0,0,1"
                BackgroundSizing="InnerBorderEdge"
                VerticalAlignment="Stretch"
                Margin="0,0,0,-8" />

        <Grid x:Name="HeaderRoot"
              Padding="8,16,8,8"
              Margin="0,0,0,-8"
              Canvas.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid x:Name="HeaderBackground"
                  BackgroundSizing="OuterBorderEdge"
                  Style="{StaticResource HeaderRootStyle}"
                  BorderThickness="0,0,0,1"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  Grid.RowSpan="4"
                  Margin="-8,-16,-8,-8" />

            <Grid x:Name="HeaderPhotoRoot"
                  Width="140"
                  Height="140"
                  Margin="12,16,12,8">

                <Border x:Name="HeaderGlow"
                        VerticalAlignment="Top"
                        Width="1000"
                        Height="320"
                        Margin="-430,-32,-430,-156" />

                <controls:ProfilePatternCover x:Name="Pattern"
                                              Loaded="Pattern_Loaded"
                                              VerticalAlignment="Top"
                                              Margin="-430,-32,-430,-156"
                                              Width="1000"
                                              Height="320"
                                              Opacity="0"
                                              RenderTransformOrigin="0.5,0.5" />

                <controls:ProfileGiftsCover x:Name="GiftsCover"
                                            TitleRoot="{x:Bind TitleRoot}"
                                            SizeChanged="GiftsCover_SizeChanged"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Center"
                                            Width="360"
                                            Margin="-110,-32,-110,-900"
                                            Height="208" />

                <Grid x:Name="HeaderPhoto"
                      Width="140"
                      Height="140"
                      VerticalAlignment="Bottom"
                      SizeChanged="HeaderPhoto_SizeChanged">
                    <controls:ActiveStoriesSegments x:Name="Segments"
                                                    Click="Segments_Click"
                                                    ContextRequested="Segments_ContextRequested"
                                                    Width="140"
                                                    Height="140"
                                                    AutomationProperties.Name="{CustomResource AccDescrProfilePicture}">
                        <Grid CornerRadius="75">
                            <controls:ProfilePicture x:Name="Photo"
                                                     Width="140"
                                                     Height="140" />
                            <controls:AnimatedImage x:Name="AnimatedPhoto"
                                                    Width="140"
                                                    Height="140"
                                                    AutoPlay="True"
                                                    FrameSize="140,140"
                                                    DecodeFrameType="Logical"
                                                    IsCachingEnabled="False"
                                                    Stretch="UniformToFill"
                                                    IsHitTestVisible="False" />
                        </Grid>
                    </controls:ActiveStoriesSegments>

                    <controls:AnimatedImage x:Name="Icon"
                                            Width="128"
                                            Height="128"
                                            FrameSize="128,128"
                                            DecodeFrameType="Logical"
                                            ReplacementColor="{ThemeResource TelegramForegroundAccentBrush}"
                                            AutoPlay="True"
                                            LoopCount="3" />

                    <Grid x:Name="TopicIconRoot"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Path x:Name="TopicIconPath"
                              Data="M4 24C4 12.9543 12.9543 4 24 4C35.0457 4 44 12.9543 44 24C44 35.0457 35.0457 44 24 44C20.5503 44 17.3015 43.1256 14.4665 41.5857L6.23091 43.9276C4.9122 44.3027 3.69397 43.0844 4.06897 41.7657L6.41149 33.5283C4.87331 30.6945 4 27.4475 4 24Z"
                              Width="128"
                              Height="128"
                              Stretch="Uniform"
                              StrokeThickness="4" />
                        <TextBlock x:Name="TopicIconText"
                                   TextAlignment="Center"
                                   Foreground="#FFFFFF"
                                   FontSize="64"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Path x:Name="TopicIconGeneral"
                          Fill="#FFFFFF"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="M22.2245 5.52551C22.3765 4.71115 21.8396 3.92775 21.0252 3.77574C20.2109 3.62372 19.4275 4.16066 19.2755 4.97502L17.4041 15.0003H7.25C6.42157 15.0003 5.75 15.6718 5.75 16.5003C5.75 17.3287 6.42157 18.0003 7.25 18.0003H16.8441L14.6041 30.0003H5.25C4.42157 30.0003 3.75 30.6718 3.75 31.5003C3.75 32.3287 4.42157 33.0003 5.25 33.0003H14.0441L12.2755 42.475C12.1235 43.2894 12.6604 44.0728 13.4748 44.2248C14.2891 44.3768 15.0725 43.8399 15.2245 43.0255L17.0959 33.0003H28.0441L26.2755 42.475C26.1235 43.2894 26.6604 44.0728 27.4748 44.2248C28.2891 44.3768 29.0725 43.8399 29.2245 43.0255L31.0959 33.0003H40.75C41.5784 33.0003 42.25 32.3287 42.25 31.5003C42.25 30.6718 41.5784 30.0003 40.75 30.0003H31.6559L33.8959 18.0003H42.75C43.5784 18.0003 44.25 17.3287 44.25 16.5003C44.25 15.6718 43.5784 15.0003 42.75 15.0003H34.4559L36.2245 5.52551C36.3765 4.71115 35.8396 3.92775 35.0252 3.77574C34.2109 3.62372 33.4275 4.16066 33.2755 4.97502L31.4041 15.0003H20.4559L22.2245 5.52551ZM28.6041 30.0003H17.6559L19.8959 18.0003H30.8441L28.6041 30.0003Z"
                          Visibility="Collapsed"
                          Width="112"
                          Height="112"
                          Stretch="Uniform" />
                </Grid>
            </Grid>

            <Grid x:Name="TitleRoot"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Center"
                  SizeChanged="TitleRoot_SizeChanged"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:CustomEmojiIcon x:Name="BotVerified"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,4,4" />

                <TextBlock x:Name="Title"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center"
                           IsTextSelectionEnabled="True"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           FontFamily="{ThemeResource EmojiThemeFontFamily}"
                           Grid.Column="1" />

                <HyperlinkButton x:Name="IdentityRoot"
                                 Click="Identity_Click"
                                 Style="{StaticResource EmptyHyperlinkButtonStyle}"
                                 VerticalAlignment="Bottom"
                                 Margin="4,0,0,4"
                                 Grid.Column="2">
                    <controls:IdentityIcon x:Name="Identity" />
                </HyperlinkButton>
            </Grid>
            <Grid x:Name="SubtitleRoot"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,0,0,8"
                  SizeChanged="SubtitleRoot_SizeChanged"
                  Grid.Row="2">
                <Grid x:Name="SubtitleMain">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <HyperlinkButton x:Name="RatingRoot"
                                     Click="Rating_Click"
                                     Style="{StaticResource EmptyHyperlinkButtonStyle}"
                                     Background="Transparent"
                                     VerticalAlignment="Bottom"
                                     Margin="0,-2,2,-4">
                        <controls:ProfileRating x:Name="Rating" />
                    </HyperlinkButton>

                    <TextBlock x:Name="Subtitle"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource PageHeaderDisabledBrush}"
                               TextAlignment="Center"
                               Grid.Column="1" />

                    <Button x:Name="SubtitleWhen"
                            Visibility="Collapsed"
                            Click="{x:Bind ViewModel.ShowLastSeen}"
                            VerticalAlignment="Bottom"
                            FontSize="11"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Padding="0"
                            Margin="4,0,0,0"
                            CornerRadius="8"
                            Height="16"
                            Grid.Column="2">
                        <TextBlock Text="{CustomResource StatusHiddenShow}"
                                   TextLineBounds="Tight"
                                   TextAlignment="Center"
                                   OpticalMarginAlignment="TrimSideBearings"
                                   FontSize="11"
                                   Padding="4,0,4,0"
                                   VerticalAlignment="Center"
                                   Typography.NumeralAlignment="Tabular" />
                    </Button>
                </Grid>
                <TextBlock x:Name="SubtitleTab"
                           Text="{x:Bind ViewModel.SelectedItem.Subtitle, Mode=OneWay}"
                           TextAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource PageHeaderDisabledBrush}"
                           IsHitTestVisible="False"
                           Visibility="Collapsed" />
            </Grid>

            <controls:ProfileButtonsGrid x:Name="Buttons"
                                         ColumnSpacing="8"
                                         Margin="16,16,16,0"
                                         MaxWidth="1000"
                                         Grid.Row="3">
                <controls:ProfileButtonsGrid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </controls:ProfileButtonsGrid.ColumnDefinitions>
                <controls:SettingsButton x:Name="OpenChat"
                                         Content="{CustomResource VoipGroupOpenChat}"
                                         Click="{x:Bind ViewModel.SendMessage}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xE9B0;" />

                <!-- User -->
                <controls:SettingsButton x:Name="Call"
                                         Content="{CustomResource Call}"
                                         Click="{x:Bind ViewModel.VoiceCall}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA52;"
                                         Grid.Column="1" />

                <controls:SettingsButton x:Name="VideoChat"
                                         Content="{CustomResource VoipGroupVoiceChat}"
                                         Click="{x:Bind ViewModel.VoiceCall}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA4F;"
                                         Grid.Column="1" />

                <controls:SettingsButton x:Name="VideoCall"
                                         Content="{CustomResource VideoCall}"
                                         Click="{x:Bind ViewModel.VideoCall}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xE964;"
                                         Grid.Column="2" />

                <controls:SettingsButton x:Name="Search"
                                         Content="{CustomResource Search}"
                                         Click="{x:Bind ViewModel.Search}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA58;"
                                         Grid.Column="2" />

                <!-- Channel -->
                <controls:SettingsButton x:Name="Edit"
                                         Content="{CustomResource ChannelEdit}"
                                         Click="{x:Bind ViewModel.Edit}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA55;"
                                         Grid.Column="2" />
                <controls:SettingsButton x:Name="Join"
                                         Content="{CustomResource ChannelJoin2}"
                                         Click="{x:Bind ViewModel.Join}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA57;"
                                         Grid.Column="2" />
                <controls:SettingsButton x:Name="Leave"
                                         Content="{CustomResource VoipGroupLeave}"
                                         Click="{x:Bind ViewModel.Delete}"
                                         Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                         Glyph="&#xEA56;"
                                         Grid.Column="2" />

                <Grid x:Name="NotificationsRoot"
                      Grid.Column="3">
                    <Border x:Name="NotificationsTarget" />
                    <controls:SettingsButton x:Name="Notifications"
                                             Click="Notifications_Click"
                                             Content="Mute"
                                             Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                             Glyph="&#xEA54;" />
                </Grid>

                <Grid x:Name="MenuRoot"
                      Grid.Column="4">
                    <Border x:Name="MenuTarget" />
                    <controls:SettingsButton x:Name="Menu"
                                             Content="{CustomResource PremiumMore}"
                                             Click="Menu_ContextRequested"
                                             Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                             Glyph="&#xEA59;" />
                </Grid>
            </controls:ProfileButtonsGrid>
        </Grid>

        <StackPanel x:Name="ControlsRoot"
                    Canvas.ZIndex="-1"
                    Grid.Row="1">
            <StackPanel x:Name="PersonalChannelRoot"
                        Visibility="Collapsed">
                <Grid Margin="24,32,24,-8"
                      MaxWidth="1000">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PersonalChannelHeader"
                               Text="{CustomResource ProfileChannel}"
                               Style="{StaticResource BaseTextBlockStyle}"
                               VerticalAlignment="Bottom" />

                    <controls:BadgeControl x:Name="PersonalChannelFooter"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Bottom"
                                           CornerRadius="4"
                                           Margin="4,0,0,0"
                                           Grid.Column="1" />
                </Grid>

                <controls:HeaderedControl>
                    <Button Click="{x:Bind ViewModel.OpenLinkedChannel}"
                            Style="{StaticResource EmptyButtonStyle}"
                            AutomationProperties.Name="{CustomResource ProfileChannel}">
                        <cells:ChatCell x:Name="PersonalChannel"
                                        Stroke="{ThemeResource ChatLastMessageStateBrush}" />
                    </Button>
                </controls:HeaderedControl>
            </StackPanel>

            <controls:HeaderedControl x:Name="InfoPanel"
                                      IsFooterLink="True">
                <controls:SettingsButton x:Name="Description"
                                         Visibility="Collapsed"
                                         ContextRequested="Description_ContextRequested"
                                         Glyph="&#xE946;">
                    <RichTextBlock x:Name="DescriptionLabel"
                                   ContextRequested="About_ContextRequested"
                                   ContextMenuOpening="About_ContextMenuOpening"
                                   Style="{StaticResource BodyRichTextBlockStyle}"
                                   FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                   Grid.Column="1">
                        <Paragraph>
                            <Span x:Name="DescriptionSpan" />
                        </Paragraph>
                    </RichTextBlock>
                </controls:SettingsButton>

                <controls:SettingsButton x:Name="UserPhone"
                                         Click="{x:Bind ViewModel.OpenPhoneInfo}"
                                         Visibility="Collapsed"
                                         Description="{CustomResource Phone}"
                                         Glyph="&#xE717;">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="{CustomResource Copy}"
                                            Click="{x:Bind ViewModel.CopyPhone}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEAC9;"
                                              Style="{StaticResource DefaultFontIconStyle}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator x:Name="AnonymousNumberSeparator"
                                                 Visibility="Collapsed" />
                            <controls:MenuFlyoutLabel x:Name="AnonymousNumber"
                                                      Visibility="Collapsed"
                                                      Text="{CustomResource AnonymousNumberNotice}"
                                                      MaxWidth="180"
                                                      Padding="12,4" />
                        </MenuFlyout>
                    </Button.ContextFlyout>
                </controls:SettingsButton>

                <controls:SettingsButton x:Name="Username"
                                         Click="{x:Bind ViewModel.ViewUsername}"
                                         Visibility="Collapsed"
                                         Glyph="&#xE168;">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="{CustomResource Copy}"
                                            Click="{x:Bind ViewModel.CopyUsername}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEAC9;"
                                              Style="{StaticResource DefaultFontIconStyle}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{CustomResource CopyLink}"
                                            Click="{x:Bind ViewModel.CopyUsernameLink}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE71B;"
                                              Style="{StaticResource DefaultFontIconStyle}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                    <controls:SettingsButton.Badge>
                        <controls:GlyphButton Content="&#xEACA;"
                                              Click="{x:Bind ViewModel.ShareUsername}"
                                              Foreground="{ThemeResource SystemColorControlAccentBrush}"
                                              AutomationProperties.Name="{CustomResource QrCode}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,-12,0" />
                    </controls:SettingsButton.Badge>
                    <controls:SettingsButton.Description>
                        <TextBlock x:Name="ActiveUsernames"
                                   Style="{StaticResource InfoCaptionTextBlockStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top" />
                    </controls:SettingsButton.Description>
                </controls:SettingsButton>

                <controls:SettingsButton x:Name="UserBirthday"
                                         Visibility="Collapsed"
                                         Click="Birthday_Click"
                                         Glyph="&#xEA84;" />

                <controls:SettingsButton x:Name="Location"
                                         Visibility="Collapsed"
                                         Description="{CustomResource AttachLocation}"
                                         Glyph="&#xE1C4;">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="{CustomResource Copy}"
                                            Click="{x:Bind ViewModel.CopyUsername}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEAC9;"
                                              Style="{StaticResource DefaultFontIconStyle}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                </controls:SettingsButton>

                <cells:ProfileHoursCell x:Name="BusinessHours"
                                        Visibility="Collapsed" />

                <controls:SettingsButton x:Name="ChatId"
                                         Click="{x:Bind ViewModel.CopyId}"
                                         Visibility="Collapsed"
                                         Glyph="&#xEA42;">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="{CustomResource Copy}"
                                            Click="{x:Bind ViewModel.CopyId}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEAC9;"
                                              Style="{StaticResource DefaultFontIconStyle}" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                    <controls:SettingsButton.ContentTemplate>
                        <DataTemplate>
                            <TextBlock>
                            <Run Text="{Binding}"
                                 FontFamily="Consolas" />
                            <Run Text="&#x2004;&#x200A;" />
                            </TextBlock>
                        </DataTemplate>
                    </controls:SettingsButton.ContentTemplate>
                </controls:SettingsButton>

                <Border x:Name="BotMainApp"
                        Visibility="Collapsed"
                        Background="{ThemeResource SettingsItemBackground}">
                    <Button Click="{x:Bind ViewModel.OpenMainWebApp}"
                            Content="{CustomResource ProfileBotOpenApp}"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="12"
                            Height="36" />
                </Border>
            </controls:HeaderedControl>

            <Grid x:Name="BotVerifiedRoot"
                  Visibility="Collapsed"
                  MaxWidth="1000"
                  Margin="24,8,24,8">
                <controls:FormattedTextBlock x:Name="BotVerifiedText"
                                             Style="{StaticResource InfoCaptionFormattedTextBlockStyle}"
                                             EmojiStyle="{StaticResource InfoCustomEmojiStyle}"
                                             IsTextSelectionEnabled="False"
                                             AutoFontSize="False" />
            </Grid>

            <controls:HeaderedControl x:Name="AffiliateProgramRoot">
                <controls:SettingsButton x:Name="AffiliateProgram"
                                         Content="{CustomResource ProfileBotAffiliateProgram}"
                                         Click="{x:Bind ViewModel.OpenAffiliate}"
                                         Glyph="&#xEAA6;"
                                         Visibility="Collapsed" />
            </controls:HeaderedControl>

            <controls:HeaderedControl>
                <controls:SettingsButton x:Name="Members"
                                         Content="{CustomResource ChannelSubscribers}"
                                         Click="{x:Bind ViewModel.OpenMembers}"
                                         Glyph="&#xE716;"
                                         Visibility="Collapsed" />
                <controls:SettingsButton x:Name="Admins"
                                         Content="{CustomResource ChannelAdministrators}"
                                         Click="{x:Bind ViewModel.OpenAdmins}"
                                         Glyph="&#xE983;"
                                         Visibility="Collapsed" />
                <controls:SettingsButton x:Name="Statistics"
                                         Click="{x:Bind ViewModel.OpenBalance}"
                                         Content="{CustomResource StarsBalance}"
                                         Glyph="&#xEA8D;"
                                         Visibility="Collapsed">
                    <controls:SettingsButton.Badge>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Visibility="{x:Bind ViewModel.CryptoCount, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xEA7E;"
                                           FontSize="16"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           Foreground="{ThemeResource SystemColorControlAccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{x:Bind ConvertCryptoCount(ViewModel.CryptoCount), Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Grid.Column="1" />
                            </Grid>

                            <Grid Visibility="{x:Bind ConvertStarVisibility(ViewModel.StarCount), Mode=OneWay}"
                                  Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <controls:PremiumStarCount Margin="8,-4,4,-6"
                                                           Width="20" />
                                <TextBlock Text="{x:Bind ConvertStarCount(ViewModel.StarCount), Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Grid.Column="1" />
                            </Grid>
                        </Grid>
                    </controls:SettingsButton.Badge>
                </controls:SettingsButton>
                <controls:SettingsButton x:Name="ChannelSettings"
                                         Content="{CustomResource ChannelAdminSettings}"
                                         Click="{x:Bind ViewModel.Edit}"
                                         Glyph="&#xE9E9;"
                                         IsChevronVisible="True"
                                         Visibility="Collapsed" />
            </controls:HeaderedControl>

            <controls:HeaderedControl x:Name="MiscPanel">
                <!--<controls:BadgeButton Content="{CustomResource SharedMedia}"
                                Command="{x:Bind ViewModel.MediaCommand}"
                                Badge="{x:Bind ViewModel.SharedMedia, Mode=OneWay}"/>-->

                <controls:SettingsButton x:Name="SecretLifetime"
                                         Visibility="Collapsed"
                                         Command="{x:Bind ViewModel.SetTimerCommand}"
                                         Content="{CustomResource MessageLifetime}"
                                         Glyph="&#xE916;" />

                <controls:SettingsButton x:Name="SecretHashKey"
                                         Visibility="Collapsed"
                                         Content="{CustomResource EncryptionKey}"
                                         Click="{x:Bind ViewModel.ShowIdenticon}"
                                         Glyph="&#xEAD1;">
                    <!--<controls:BadgeButton.Badge>
                                    <Image x:Name="SecretIdenticon" Width="24" Height="24"/>
                                    </controls:BadgeButton.Badge>-->
                </controls:SettingsButton>
            </controls:HeaderedControl>
        </StackPanel>
    </Grid>
</UserControl>
