<UserControl x:Class="Telegram.Controls.Drawers.EmojiDrawer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:common="using:Telegram.Common"
             xmlns:controls="using:Telegram.Controls"
             xmlns:selectors="using:Telegram.Selectors"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <UserControl.Resources>
        <CollectionViewSource x:Name="EmojiCollection"
                              Source="{x:Bind ViewModel.Items}"
                              IsSourceGrouped="True"
                              ItemsPath="Stickers" />

        <DataTemplate x:Key="EmojiTemplate"
                      x:DataType="common:EmojiData">
            <TextBlock x:Phase="0"
                       Text="{x:Bind Value, Mode=OneTime}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontFamily="{ThemeResource EmojiThemeFontFamily}" />
        </DataTemplate>

        <DataTemplate x:Key="EmojiSkinTemplate"
                      x:DataType="common:EmojiSkinData">
            <TextBlock x:Phase="0"
                       Text="{x:Bind Value, Mode=OneWay}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontFamily="{ThemeResource EmojiThemeFontFamily}" />
        </DataTemplate>

        <DataTemplate x:Key="ItemTemplate">
            <Grid Background="Transparent">
                <controls:AnimatedImage x:Name="Player"
                                        AutoPlay="False"
                                        LimitFps="True"
                                        FrameSize="32,32"
                                        DecodeFrameType="Logical"
                                        Width="32"
                                        Height="32"
                                        Ready="Player_Ready"
                                        ReplacementColor="{ThemeResource TelegramForegroundAccentBrush}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MoreTemplate">
            <Grid Background="{ThemeResource MessageOverlayBackgroundBrush}"
                  CornerRadius="{ThemeResource MessageOverlayCornerRadius}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="6,1,6,3">
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="White"
                           TextAlignment="Right"
                           TextWrapping="NoWrap" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <GridView x:Name="List"
                  ItemsSource="{x:Bind EmojiCollection.View, Mode=OneWay}"
                  common:FluidGridView.OrientationOnly="False"
                  ChoosingItemContainer="OnChoosingItemContainer"
                  ChoosingGroupHeaderContainer="OnChoosingGroupHeaderContainer"
                  ContainerContentChanging="OnContainerContentChanging"
                  ItemClick="ListView_ItemClick"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  Loaded="OnLoaded"
                  Grid.Row="1">
            <common:FluidGridView.Triggers>
                <common:FluidGridViewTrigger Activated="FluidGridViewTrigger_Activated"
                                             RowsOrColumns="8" />
            </common:FluidGridView.Triggers>
            <GridView.Header>
                <StackPanel>
                    <controls:EmojiSearchBox x:Name="SearchField"
                                             AllowFocusOnInteraction="True"
                                             PlaceholderText="{CustomResource Search}"
                                             CategorySelected="SearchField_CategorySelected"
                                             Margin="12,8,12,8" />

                    <Grid x:Name="DefaultIcon"
                          HorizontalAlignment="Left"
                          Padding="0,0,4,4">
                        <Grid x:Name="TopicIconRoot"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed">
                            <Path x:Name="TopicIconPath"
                                  Data="M2.00003 14C2.00003 7.37258 7.37261 2 14 2C20.6274 2 26 7.37258 26 14C26 20.6274 20.6274 26 14 26C11.964 26 10.0446 25.4924 8.36332 24.5963L3.59342 25.9527C2.65148 26.2206 1.78133 25.3504 2.04919 24.4085L3.40531 19.6396C2.50826 17.9577 2.00003 16.0372 2.00003 14Z" />
                            <TextBlock x:Name="TopicIconText"
                                       TextAlignment="Center"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       Margin="0,2,0,0"
                                       Width="28" />
                        </Grid>
                        <TextBlock x:Name="EmojiStatusIconRoot"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xEA87;"
                                   Foreground="{ThemeResource TelegramForegroundAccentBrush}"
                                   FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                   FontSize="24"
                                   Visibility="Collapsed" />
                    </Grid>
                </StackPanel>
            </GridView.Header>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="MinWidth"
                            Value="0" />
                    <Setter Property="MinHeight"
                            Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridViewItem">
                                <ContentPresenter HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Stretch"
                                                  Padding="0" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <!--<DataTemplate x:DataType="common:EmojiGroup">
                            <TextBlock Text="{x:Bind Title}"
                                       Foreground="{ThemeResource SystemControlDisabledChromeDisabledLowBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </DataTemplate>-->
                        <DataTemplate>
                            <Grid Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"
                                  Padding="0,6,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="NoWrap"
                                           Style="{StaticResource InfoBodyTextBlockStyle}" />

                                <controls:SettingsButton Content="{CustomResource Add}"
                                                      Visibility="{Binding IsInstalled, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                                      Style="{StaticResource PillButtonStyle}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Padding="12,1,12,2"
                                                      CornerRadius="12"
                                                      Margin="0,-6"
                                                      Grid.Column="1" />
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                    <GroupStyle.HeaderContainerStyle>
                        <Style TargetType="GridViewHeaderItem">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="FontFamily"
                                    Value="{ThemeResource ContentControlThemeFontFamily}" />
                            <Setter Property="FontSize"
                                    Value="{ThemeResource ListViewHeaderItemThemeFontSize}" />
                            <Setter Property="Margin"
                                    Value="0,0,0,0" />
                            <Setter Property="Padding"
                                    Value="10,0,10,0" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Top" />
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="UseSystemFocusVisuals"
                                    Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewHeaderItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter x:Name="ContentPresenter"
                                                              Margin="{TemplateBinding Padding}"
                                                              Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                </GroupStyle>
            </GridView.GroupStyle>
            <GridView.ItemContainerTransitions>
                <TransitionCollection />
            </GridView.ItemContainerTransitions>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   AreStickyGroupHeadersEnabled="False" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>

        <Grid x:Name="ToolbarContainer">
            <Border x:Name="Separator" />

            <GridView x:Name="Toolbar2"
                      ItemsSource="{x:Bind ViewModel.InstalledSets}"
                      Height="40"
                      IsItemClickEnabled="True"
                      ItemClick="Toolbar_ItemClick"
                      SelectionChanged="Toolbar_SelectionChanged"
                      ContainerContentChanging="Toolbar_ContainerContentChanging"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ScrollViewer.HorizontalScrollMode="Auto"
                      ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      Padding="4,0,0,0"
                      Grid.Row="0">
                <GridView.Header>
                    <Grid x:Name="Toolbar3"
                          Margin="0,0,4,0">
                        <Border x:Name="ToolbarPill"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                CornerRadius="4"
                                Height="32" />
                        <GridView x:Name="Toolbar"
                                  ItemsSource="{x:Bind ViewModel.StandardSets}"
                                  Height="32"
                                  Width="144"
                                  IsItemClickEnabled="True"
                                  ItemClick="Toolbar_ItemClick"
                                  SelectionChanged="Toolbar_SelectionChanged"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollMode="Auto"
                                  ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled"
                                  Padding="0">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal"
                                                     HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem"
                                       BasedOn="{StaticResource DefaultGridViewItemStyle}">
                                    <Setter Property="Margin"
                                            Value="0,0,0,0" />
                                    <Setter Property="MinHeight"
                                            Value="0" />
                                    <Setter Property="MinWidth"
                                            Value="0" />
                                    <Setter Property="Height"
                                            Value="32" />
                                    <Setter Property="Width"
                                            Value="32" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="common:EmojiGroup">
                                    <Border AutomationProperties.Name="{x:Bind Title}"
                                            ToolTipService.ToolTip="{x:Bind Title}"
                                            Background="Transparent">
                                        <TextBlock Text="{x:Bind Glyph}"
                                                   FontFamily="{StaticResource TelegramThemeFontFamily}"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsColorFontEnabled="False"
                                                   Margin="0" />
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                            <GridView.ItemContainerTransitions>
                                <TransitionCollection />
                            </GridView.ItemContainerTransitions>
                        </GridView>
                    </Grid>
                </GridView.Header>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem"
                           BasedOn="{StaticResource DefaultGridViewItemStyle}">
                        <Setter Property="Margin"
                                Value="0,2,4,2" />
                        <Setter Property="MinHeight"
                                Value="0" />
                        <Setter Property="MinWidth"
                                Value="0" />
                        <Setter Property="Height"
                                Value="32" />
                        <Setter Property="Width"
                                Value="32" />
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplateSelector>
                    <selectors:StickerSetTemplateSelector>
                        <selectors:StickerSetTemplateSelector.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <controls:AnimatedImage x:Name="Player"
                                                            AutoPlay="False"
                                                            LimitFps="True"
                                                            FrameSize="24,24"
                                                            DecodeFrameType="Logical"
                                                            Ready="Toolbar_Ready"
                                                            Width="24"
                                                            Height="24"
                                                            ReplacementColor="{ThemeResource TelegramForegroundAccentBrush}" />
                                </Grid>
                            </DataTemplate>
                        </selectors:StickerSetTemplateSelector.ItemTemplate>
                        <selectors:StickerSetTemplateSelector.GroupTemplate>
                            <DataTemplate>
                                <controls:ProfilePicture Margin="6" />
                            </DataTemplate>
                        </selectors:StickerSetTemplateSelector.GroupTemplate>
                        <selectors:StickerSetTemplateSelector.IconTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <FontIcon FontFamily="{StaticResource TelegramThemeFontFamily}" />
                                </Grid>
                            </DataTemplate>
                        </selectors:StickerSetTemplateSelector.IconTemplate>
                    </selectors:StickerSetTemplateSelector>
                </GridView.ItemTemplateSelector>
                <!--<GridView.Footer>
                    <StackPanel Orientation="Horizontal">
                        <controls:GlyphButton Click="Settings_Click"
                                              Width="{ThemeResource AppBarThemeCompactHeight}"
                                              Height="{ThemeResource AppBarThemeCompactHeight}"
                                              Glyph="&#xE713;" />
                    </StackPanel>
                </GridView.Footer>-->
                <GridView.ItemContainerTransitions>
                    <TransitionCollection />
                </GridView.ItemContainerTransitions>
            </GridView>
        </Grid>
    </Grid>
</UserControl>
