<controls:UserControlEx x:Class="Telegram.Controls.PlaybackHeader"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="using:Telegram.Controls"
                        xmlns:cells="using:Telegram.Controls.Cells"
                        xmlns:controls="using:Telegram.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        mc:Ignorable="d"
                        d:DesignHeight="300"
                        d:DesignWidth="400">

    <controls:UserControlEx.Resources>
        <Style TargetType="controls:PlaybackSlider">
            <Setter Property="UseSystemFocusVisuals"
                    Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:PlaybackSlider">
                        <Grid Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition From="PointerOver"
                                                          To="Normal">
                                            <Storyboard>
                                                <DoubleAnimation Duration="{ThemeResource ScrollBarExpandDuration}"
                                                                 Storyboard.TargetName="ProgressBarIndicatorTransform"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 To="0.3333333333333333" />
                                                <DoubleAnimation Duration="{ThemeResource ScrollBarExpandDuration}"
                                                                 Storyboard.TargetName="ProgressBarIndicatorTransform"
                                                                 Storyboard.TargetProperty="TranslateY"
                                                                 To="4" />
                                            </Storyboard>
                                        </VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Duration="{ThemeResource ScrollBarExpandDuration}"
                                                             Storyboard.TargetName="ProgressBarIndicatorTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" />
                                            <DoubleAnimation Duration="{ThemeResource ScrollBarExpandDuration}"
                                                             Storyboard.TargetName="ProgressBarIndicatorTransform"
                                                             Storyboard.TargetProperty="TranslateY"
                                                             To="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid x:Name="LayoutRoot"
                                  Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                <Grid.RenderTransform>
                                    <CompositeTransform x:Name="ProgressBarIndicatorTransform"
                                                        ScaleX="1.0"
                                                        ScaleY="0.3333333333333333"
                                                        TranslateX="0"
                                                        TranslateY="4" />
                                </Grid.RenderTransform>
                                <Border x:Name="ProgressBarIndicator"
                                        Background="{ThemeResource SystemControlHighlightAccentBrush}" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThreeStateToggleStyle"
               TargetType="controls:GlyphToggleButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="UncheckedForeground"
                    Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="CheckedForeground"
                    Value="{ThemeResource SystemControlHighlightBaseMediumHighBrush}" />
            <Setter Property="BorderBrush"
                    Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalAlignment"
                    Value="Top" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="FontFamily"
                    Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize"
                    Value="{StaticResource GlyphMediumFontSize}" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Height"
                    Value="48" />
            <Setter Property="Width"
                    Value="48" />
            <Setter Property="UseSystemFocusVisuals"
                    Value="True" />
            <Setter Property="FocusVisualMargin"
                    Value="-3" />
            <Setter Property="CornerRadius"
                    Value="{StaticResource GlyphButtonCornerRadius}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:GlyphToggleButton">
                        <Grid Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Margin="{StaticResource GlyphButtonPadding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListLowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListMediumBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Foreground"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{TemplateBinding UncheckedForeground}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="CheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="CheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListLowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="CheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListMediumBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedDisabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="CheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="IndeterminateContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="IndeterminatePointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="IndeterminateContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListLowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="IndeterminatePressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="IndeterminateContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background"
                                                                           Storyboard.TargetName="RootGrid">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{ThemeResource SystemControlBackgroundListMediumBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="IndeterminateDisabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="UncheckedContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="IndeterminateContentPresenter">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid x:Name="RootGrid">
                                <TextBlock x:Name="IndeterminateContentPresenter"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{TemplateBinding CheckedForeground}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           AutomationProperties.AccessibilityView="Raw"
                                           Text="{TemplateBinding IndeterminateGlyph}"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="CheckedContentPresenter"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{TemplateBinding CheckedForeground}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           AutomationProperties.AccessibilityView="Raw"
                                           Text="{TemplateBinding CheckedGlyph}"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="UncheckedContentPresenter"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{TemplateBinding UncheckedForeground}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           AutomationProperties.AccessibilityView="Raw"
                                           Text="{TemplateBinding Glyph}" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </controls:UserControlEx.Resources>

    <Grid Background="{ThemeResource PageSubHeaderBackgroundBrush2}">
        <Button x:Name="ViewButton"
                Click="View_Click"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Center"
                Padding="54,0,96,0"
                Background="Transparent"
                Style="{StaticResource ListEmptyButtonStyle}"
                AutomationProperties.Name="{CustomResource AccDescrOpenChat}">
            <Grid Margin="0,-2,0,0">
                <TextBlock x:Name="Label1"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontFamily="{ThemeResource EmojiThemeFontFamily}">
                    <Run x:Name="TitleLabel1"
                         FontWeight="SemiBold" />
                    <Run x:Name="SubtitleLabel1" />
                </TextBlock>

                <TextBlock x:Name="Label2"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           Style="{StaticResource BodyTextBlockStyle}"
                           FontFamily="{ThemeResource EmojiThemeFontFamily}">
                    <Run x:Name="TitleLabel2"
                         FontWeight="SemiBold" />
                    <Run x:Name="SubtitleLabel2" />
                </TextBlock>
            </Grid>
        </Button>

        <Grid x:Name="LeftButtons"
              SizeChanged="Buttons_SizeChanged"
              HorizontalAlignment="Left"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <controls:PlaybackNextButton x:Name="PreviousButton"
                                         Click="Previous_Click"
                                         IsPrevious="True"
                                         Glyph="&#xE892;"
                                         Foreground="{ThemeResource SystemControlBackgroundAccentBrush}"
                                         Width="40"
                                         Height="40"
                                         Margin="0,0,-4,0"
                                         AutomationProperties.Name="{CustomResource AccDescrPrevious}"
                                         ToolTipService.ToolTip="{CustomResource AccDescrPrevious}" />
            <controls:AnimatedGlyphButton x:Name="PlaybackButton"
                                          Click="Toggle_Click"
                                          Glyph="&#xE768;"
                                          Foreground="{ThemeResource SystemControlBackgroundAccentBrush}"
                                          Width="48"
                                          Height="40"
                                          Grid.Column="1" />
            <controls:PlaybackNextButton x:Name="NextButton"
                                         Click="Next_Click"
                                         IsPrevious="False"
                                         Glyph="&#xE893;"
                                         Foreground="{ThemeResource SystemControlBackgroundAccentBrush}"
                                         Width="40"
                                         Height="40"
                                         Margin="-4,0,0,0"
                                         Grid.Column="2"
                                         AutomationProperties.Name="{CustomResource Next}"
                                         ToolTipService.ToolTip="{CustomResource Next}" />
        </Grid>

        <Grid x:Name="RightButtons"
              SizeChanged="Buttons_SizeChanged"
              HorizontalAlignment="Right"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:GlyphButton x:Name="VolumeButton"
                                  Click="VolumeButton_Click"
                                  Glyph="&#xE74F;"
                                  Width="40"
                                  Height="40"
                                  Foreground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
                                  AutomationProperties.Name="{CustomResource VoipGroupVolume}"
                                  ToolTipService.ToolTip="{CustomResource VoipGroupVolume}" />

            <TextBlock x:Name="SpeedText"
                       Foreground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
                       TextAlignment="Center"
                       Typography.NumeralAlignment="Tabular"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="10"
                       Margin="0,5,0,6"
                       Grid.Column="1" />

            <controls:SettingsButton x:Name="SpeedButton"
                                     Click="Speed_Click"
                                     Foreground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
                                     Glyph="&#xEA13;"
                                     Width="40"
                                     Height="40"
                                     MinHeight="40"
                                     Padding="8"
                                     Grid.Column="1"
                                     AutomationProperties.Name="{CustomResource Speed}"
                                     ToolTipService.ToolTip="{CustomResource Speed}"
                                     Style="{StaticResource DefaultGlyphButtonStyle}"
                                     Visibility="Collapsed" />

            <controls:GlyphToggleButton x:Name="RepeatButton"
                                        Click="Repeat_Click"
                                        UncheckedForeground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
                                        CheckedForeground="{ThemeResource SystemControlForegroundAccentBrush}"
                                        Glyph="&#xEA14;"
                                        CheckedGlyph="&#xEA14;"
                                        IndeterminateGlyph="&#xEA15;"
                                        Width="40"
                                        Height="40"
                                        Grid.Column="2"
                                        IsOneWay="False"
                                        IsThreeState="True"
                                        Style="{StaticResource ThreeStateToggleStyle}" />
            <controls:GlyphToggleButton x:Name="ShuffleButton"
                                        Click="Shuffle_Click"
                                        UncheckedForeground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
                                        CheckedForeground="{ThemeResource SystemControlForegroundAccentBrush}"
                                        Glyph="&#xE8CB;"
                                        CheckedGlyph="&#xE8CB;"
                                        Width="40"
                                        Height="40"
                                        Grid.Column="3"
                                        IsOneWay="False"
                                        AutomationProperties.Name="{CustomResource ReverseOrder}"
                                        ToolTipService.ToolTip="{CustomResource ReverseOrder}" />

            <!--<controls:GlyphToggleButton
            x:Name="ShuffleButton"
            Click="Shuffle_Click"
            UncheckedForeground="{ThemeResource SystemControlForegroundChromeDisabledLowBrush}"
            CheckedForeground="{ThemeResource SystemControlForegroundAccentBrush}"
            Glyph="&#xE8B1;"
            CheckedGlyph="&#xE8B1;"
            Width="40"
            Height="40"
            Grid.Column="5"
            AutomationProperties.Name="{CustomResource Shuffle}"
            ToolTipService.ToolTip="{CustomResource Shuffle}"/>-->
            <controls:GlyphButton Click="Clear_Click"
                                  Glyph="&#xE711;"
                                  Width="48"
                                  Height="40"
                                  Grid.Column="4"
                                  AutomationProperties.Name="{CustomResource AccDescrClosePlayer}"
                                  ToolTipService.ToolTip="{CustomResource AccDescrClosePlayer}" />
        </Grid>

        <controls:PlaybackSlider x:Name="Slider"
                                 Height="6"
                                 VerticalAlignment="Bottom" />
    </Grid>
</controls:UserControlEx>
