                        <controls:FormattedTextBlock x:Name="Text"
                                                     Foreground="#FFFFFF"
                                                     TextAlignment="Center"
                                                     Style="{StaticResource CaptionFormattedTextBlockStyle}"
                                                     FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}"
                                                     AutoFontSize="False"
                                                     IsTextSelectionEnabled="False"
                                                     HyperlinkStyle="None"
                                                     HyperlinkForeground="#FFFFFF"
                                                     HyperlinkFontWeight="SemiBold"
                                                     Padding="0,0,0,4" />
                    </messages:MessageService>

                    <Grid Width="216">
                        <Border BorderBrush="{ThemeResource MessageServiceBackgroundBrush}"
                                BorderThickness="6"
                                CornerRadius="12"
                                Margin="0,4,0,0" />

                        <controls:PatternBackground x:Name="Pattern"
                                                    Margin="4,8,4,4"
                                                    Padding="0,12,0,8"
                                                    CornerRadius="12"
                                                    Width="208">
                            <controls:PatternBackground.Footer>
                                <Grid HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="Title"
                                               Foreground="#FFFFFF"
                                               Text="{CustomResource BoostingCongratulations}"
                                               TextAlignment="Center"
                                               Style="{StaticResource SubtitleTextBlockStyle}"
                                               FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}"
                                               FontSize="16"
                                               Grid.ColumnSpan="2" />
                                    <TextBlock x:Name="Subtitle"
                                               Foreground="#AAFFFFFF"
                                               TextAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}"
                                               Margin="0,0,0,8"
                                               Grid.ColumnSpan="2"
                                               Grid.Row="1" />

                                    <TextBlock x:Name="AttributeInfo"
                                               Text="{CustomResource Gift2AttributeModel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="#AAFFFFFF"
                                               TextAlignment="Right"
                                               TextWrapping="NoWrap"
                                               Margin="0,0,4,0"
                                               Grid.Row="2" />
                                    <TextBlock x:Name="AttributeText"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               TextWrapping="NoWrap"
                                               Margin="4,0,0,0"
                                               Grid.Column="1"
                                               Grid.Row="2" />

                                    <Border x:Name="View"
                                            Background="{ThemeResource MessageServiceBackgroundBrush}"
                                            CornerRadius="14"
                                            HorizontalAlignment="Center"
                                            Padding="12,3,12,5"
                                            Margin="0,8,0,12"
                                            Grid.ColumnSpan="2"
                                            Grid.Row="3">
                                        <TextBlock x:Name="ViewLabel"
                                                   Text="{CustomResource Gift2UniqueView}"
                                                   Foreground="#FFFFFF"
                                                   TextAlignment="Center"
                                                   Style="{StaticResource BaseTextBlockStyle}" />
                                    </Border>
                                </Grid>
                            </controls:PatternBackground.Footer>
                            <controls:AnimatedImage x:Name="Animation"
                                                    Width="120"
                                                    Height="120"
                                                    FrameSize="120,120"
                                                    DecodeFrameType="Logical"
                                                    IsViewportAware="True"
                                                    LoopCount="1" />
                            <!--<StackPanel>

