<controls:ContentPopup x:Class="Telegram.Views.Popups.QrCodePopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:chats="using:Telegram.Controls.Chats"
                       xmlns:common="using:Telegram.Common"
                       xmlns:cells="using:Telegram.Controls.Cells"
                       xmlns:icons="using:Telegram.Assets.Icons"
                       Title="{x:Null}"
                       ContentMaxHeight="8000"
                       Padding="0"
                       mc:Ignorable="d">

    <Grid x:Name="LayoutRoot"
          ActualThemeChanged="OnActualThemeChanged">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid x:Name="RootGrid">
                    <chats:ChatBackgroundPresenter x:Name="Preview"
                                                   CornerRadius="6,6,0,0" />

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="24,60,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                CornerRadius="15"
                                Grid.RowSpan="3" />

                        <controls:ProfilePicture x:Name="Photo"
                                                 Size="96"
                                                 Margin="0,-48,0,0" />

                        <Border x:Name="Code"
                                Width="222"
                                Height="222"
                                Margin="24,12"
                                Grid.Row="1" />

                        <controls:AnimatedImage Source="ms-appx:///Assets/Animations/QrLogo.json"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Width="32"
                                                Height="32"
                                                FrameSize="32,32"
                                                DecodeFrameType="Logical"
                                                AutoPlay="True"
                                                Grid.Row="1" />

                        <Viewbox StretchDirection="DownOnly"
                                 Margin="12,0,12,8"
                                 Height="36"
                                 Grid.Row="2">
                            <controls:AnimatedTextBlock x:Name="Username"
                                                        TextAlignment="Center">
                                <controls:AnimatedTextBlock.TextStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily"
                                                Value="/Assets/Fonts/Nunito.ttf#Nunito" />
                                        <Setter Property="FontSize"
                                                Value="24" />
                                    </Style>
                                </controls:AnimatedTextBlock.TextStyle>
                            </controls:AnimatedTextBlock>
                        </Viewbox>
                    </Grid>
                </Grid>

                <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                      Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{CustomResource QrCode}"
                               TextAlignment="Center"
                               Style="{StaticResource BaseTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="24,0,0,0" />

                    <controls:AnimatedIconToggleButton x:Name="Theme"
                                                       Click="Theme_Click"
                                                       CheckedGlyph="&#xE9EE;"
                                                       Glyph="&#xE9EA;"
                                                       VerticalAlignment="Top"
                                                       HorizontalAlignment="Left"
                                                       IsTabStop="False"
                                                       FontSize="{StaticResource GlyphMediumFontSize}"
                                                       CornerRadius="20"
                                                       Width="48"
                                                       Height="48">
                        <controls:AnimatedIconToggleButton.Source>
                            <icons:Sun />
                        </controls:AnimatedIconToggleButton.Source>
                    </controls:AnimatedIconToggleButton>

                    <controls:GlyphButton x:Name="Close"
                                          HorizontalAlignment="Right"
                                          Click="Close_Click"
                                          Glyph="&#xE711;"
                                          CornerRadius="20" />

                    <GridView x:Name="ScrollingHost"
                              ContainerContentChanging="OnContainerContentChanging"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollMode="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              Padding="24,0,22,0"
                              Grid.Row="1">
                        <common:FluidGridView.Triggers>
                            <common:FluidGridViewTrigger RowsOrColumns="3" />
                        </common:FluidGridView.Triggers>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem"
                                   BasedOn="{StaticResource DefaultGridViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <cells:ChatThemeCell Width="87" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerTransitions>
                            <TransitionCollection />
                        </GridView.ItemContainerTransitions>
                    </GridView>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Grid.Row="1">
            <Button Click="Share_Click"
                    Content="{CustomResource ShareQrCode}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Margin="24,10,24,24"
                    Grid.Row="2" />
        </Grid>

        <Border x:Name="Transition"
                Grid.RowSpan="2" />
    </Grid>
</controls:ContentPopup>
