                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <controls:FormattedTextBox x:Name="Text"
                                                               PlaceholderText="{CustomResource OptionHint}"
                                                               FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                                               AllowedEntities="CustomEmoji"
