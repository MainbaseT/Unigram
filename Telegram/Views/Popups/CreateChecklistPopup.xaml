<controls:ContentPopup x:Class="Telegram.Views.Popups.CreateChecklistPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:local="using:Telegram.Views.Popups"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:messages="using:Telegram.Controls.Messages"
                       xmlns:drawers="using:Telegram.Controls.Drawers"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       mc:Ignorable="d"
                       Closing="OnClosing"
                       DefaultButton="None"
                       Padding="0,16,0,0">

    <FlyoutBase.AttachedFlyout>
        <Flyout x:Name="EmojiFlyout"
                Closed="EmojiFlyout_Closed"
                Placement="Top"
                ShowMode="Transient">
            <Flyout.FlyoutPresenterStyle>
                <Style TargetType="FlyoutPresenter"
                       BasedOn="{StaticResource CommandFlyoutPresenterStyle}">
                    <Setter Property="Padding"
                            Value="0" />
                </Style>
            </Flyout.FlyoutPresenterStyle>
            <drawers:EmojiDrawer x:Name="EmojiPanel"
                                 ItemClick="Emoji_ItemClick"
                                 Width="300"
                                 Height="360" />
        </Flyout>
    </FlyoutBase.AttachedFlyout>

    <Grid>
        <ListView x:Name="ScrollingHost"
                  ItemsSource="{x:Bind Items}"
                  ContainerContentChanging="OnContainerContentChanging"
                  DragItemsStarting="OnDragItemsStarting"
                  DragItemsCompleted="OnDragItemsCompleted"
                  SelectionMode="None"
                  CanReorderItems="True"
                  CanDragItems="True"
                  AllowDrop="True"
                  Padding="0,0,0,16">
            <ListView.Header>
                <StackPanel>
                    <StackPanel x:Name="TitleRoot">
                        <!-- TODO: I don't like that there's no header here -->
                        <!--<TextBlock Text="{CustomResource Question}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   Margin="24,16,24,8" />-->
                        <Grid Margin="24,8,24,8">
                            <controls:FormattedTextBox x:Name="TitleText"
                                                       TextChanged="Title_TextChanged"
                                                       CustomEmoji="{x:Bind CustomEmoji}"
                                                       PlaceholderText="{CustomResource TodoTitlePlaceholder}"
                                                       FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                                       AcceptsReturn="True"
                                                       TextWrapping="Wrap"
                                                       MaxLength="255"
                                                       Padding="10,5,36,6" />

                            <messages:CustomEmojiCanvas x:Name="CustomEmoji"
                                                        IsHitTestVisible="False"
                                                        Margin="10,4,-2,-2" />

                            <controls:GlyphButton Click="Emoji_Click"
                                                  Tag="{x:Bind TitleText}"
                                                  Glyph="&#xE76E;"
                                                  AutomationProperties.Name="{CustomResource Emoji}"
                                                  IsTabStop="False"
                                                  AllowFocusOnInteraction="False"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Width="36"
                                                  Height="32" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="{CustomResource TodoItemsTitle}"
                               Style="{StaticResource BaseTextBlockStyle}"
                               Margin="24,16,24,0" />
                </StackPanel>
            </ListView.Header>
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <ContentThemeTransition />
                    <ReorderThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem"
                       BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="Margin"
                            Value="24,8,24,0" />
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="MinHeight"
                            Value="0" />
                    <Setter Property="IsTabStop"
                            Value="False" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <controls:FormattedTextBox x:Name="Text"
                                                       PlaceholderText="{CustomResource TodoTaskPlaceholder}"
                                                       FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                                       Padding="28,5,64,6"
                                                       MaxLength="100"
                                                       Loaded="Task_Loaded"
                                                       PreviewKeyDown="Task_PreviewKeyDown"
                                                       TextChanged="Task_TextChanged"
                                                       GotFocus="Task_GotFocus"
                                                       LostFocus="Task_LostFocus"
                                                       Grid.ColumnSpan="3" />

                            <messages:CustomEmojiCanvas x:Name="CustomEmoji"
                                                        IsHitTestVisible="False"
                                                        Margin="28,4,-2,-2"
                                                        Grid.ColumnSpan="3" />

                            <Border x:Name="Handle"
                                    Background="Transparent"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="&#xE9F6;"
                                           VerticalAlignment="Center"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16"
                                           Margin="8,0,0,0" />
                            </Border>

                            <controls:GlyphButton x:Name="Emoji"
                                                  Click="Emoji_Click"
                                                  Glyph="&#xE76E;"
                                                  AutomationProperties.Name="{CustomResource Emoji}"
                                                  IsTabStop="False"
                                                  AllowFocusOnInteraction="False"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed"
                                                  Margin="0,0,-8,0"
                                                  Width="36"
                                                  Height="32"
                                                  Grid.Column="1" />

                            <controls:GlyphButton x:Name="Remove"
                                                  Glyph="&#xE711;"
                                                  IsTabStop="False"
                                                  AutomationProperties.AccessibilityView="Raw"
                                                  FontSize="16"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  Width="36"
                                                  Height="32"
                                                  Grid.Column="2" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <StackPanel>
                    <Grid x:Name="AddTaskRoot"
                          Margin="24,8,24,0">
                        <controls:FormattedTextBox x:Name="AddTask"
                                                   CustomEmoji="{x:Bind AddTaskCustomEmoji}"
                                                   PlaceholderText="{CustomResource TodoNewTask}"
                                                   TextChangedForRealNoCap="AddTask_TextChanged"
                                                   GotFocus="AddTask_GotFocus"
                                                   LostFocus="AddTask_LostFocus" />

                        <messages:CustomEmojiCanvas x:Name="AddTaskCustomEmoji"
                                                    IsHitTestVisible="False"
                                                    Margin="10,4,-2,-2" />

                        <controls:GlyphButton x:Name="AddTaskEmoji"
                                              Tag="{x:Bind AddTask}"
                                              Click="Emoji_Click"
                                              Glyph="&#xE76E;"
                                              AutomationProperties.Name="{CustomResource Emoji}"
                                              IsTabStop="False"
                                              AllowFocusOnInteraction="False"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Bottom"
                                              Visibility="Collapsed"
                                              Width="36"
                                              Height="32" />
                    </Grid>
                    <TextBlock x:Name="AddInfo"
                               Style="{StaticResource InfoCaptionTextBlockStyle}"
                               Margin="24,8" />

                    <controls:HeaderedControl x:Name="Settings"
                                              Header="{CustomResource Settings}"
                                              BorderThickness="0">
                        <StackPanel>
                            <CheckBox x:Name="OthersCanMarkTasksAsDoneButton"
                                      Content="{CustomResource TodoAllowMarkingDone}"
                                      Click="OthersCanMarkTasksAsDone_Click" />

                            <CheckBox x:Name="OthersCanAddTasksButton"
                                      Content="{CustomResource TodoAllowAddingTasks}" />
                        </StackPanel>
                    </controls:HeaderedControl>
                </StackPanel>
            </ListView.Footer>
        </ListView>

        <controls:ScrollViewerScrim Background="{ThemeResource ContentDialogBackground}"
                                    ScrollingHost="{x:Bind ScrollingHost}" />
    </Grid>
</controls:ContentPopup>
