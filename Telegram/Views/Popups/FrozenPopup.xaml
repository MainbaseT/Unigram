<controls:ContentPopup x:Class="Telegram.Views.Popups.FrozenPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:common="using:Telegram.Common"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Padding="24,12,24,24">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <controls:AnimatedImage Source="ms-appx:///Assets/Animations/BlockedChats.tgs"
                                IsCachingEnabled="False"
                                AutoPlay="True"
                                FrameSize="140,140"
                                DecodeFrameType="Logical"
                                Width="140"
                                Height="140"
                                Margin="0,0,0,12" />

        <TextBlock Text="{CustomResource AccountFrozenTitle}"
                   Style="{StaticResource PopupTextBlockStyle}"
                   TextAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,0,0,8"
                   Grid.Row="1" />

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE98B;"
                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                       FontSize="20"
                       Margin="0,0,12,0" />

            <TextBlock Text="{CustomResource AccountFrozen1Title}"
                       Style="{StaticResource BaseTextBlockStyle}"
                       Grid.Column="1" />

            <TextBlock Text="{CustomResource AccountFrozen1Text}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,12"
                       Grid.Column="1"
                       Grid.Row="1" />

            <TextBlock Text="&#xEAA3;"
                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                       FontSize="20"
                       Margin="0,0,12,0"
                       Grid.Row="2" />

            <TextBlock Text="{CustomResource AccountFrozen2Title}"
                       Style="{StaticResource BaseTextBlockStyle}"
                       Grid.Column="1"
                       Grid.Row="2" />

            <TextBlock Text="{CustomResource AccountFrozen2Text}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Margin="0,0,0,12"
                       Grid.Column="1"
                       Grid.Row="3" />

            <TextBlock Text="&#xEAA8;"
                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                       FontSize="20"
                       Margin="0,0,12,0"
                       Grid.Row="4" />

            <TextBlock Text="{CustomResource AccountFrozen3Title}"
                       Style="{StaticResource BaseTextBlockStyle}"
                       Grid.Column="1"
                       Grid.Row="4" />

            <TextBlock x:Name="Line3"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Grid.Column="1"
                       Grid.Row="5" />
        </Grid>
    </Grid>
</controls:ContentPopup>
