<controls:ContentPopup x:Class="Telegram.Views.Popups.CocoonAboutPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:common="using:Telegram.Common"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Padding="0"
                       IsDismissButtonVisible="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:AnimatedImage Source="ms-appx:///Assets/Animations/Cocoon.webp"
                                    IsCachingEnabled="False"
                                    AutoPlay="True"
                                    FrameSize="120,120"
                                    DecodeFrameType="Logical"
                                    LoopCount="1"
                                    Width="120"
                                    Height="120"
                                    Margin="0,12,0,12" />

            <TextBlock Text="COCOON"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="12,0,12,8"
                       Grid.Row="1" />

            <TextBlock common:TextBlockHelper.Markdown="{CustomResource CocoonSubtitle}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="12,0,12,0"
                       Grid.Row="2" />

            <controls:PopupInfo x:Name="Feature1"
                                Click="Feature1_Click"
                                Title="{CustomResource CocoonFeature1Title}"
                                Glyph="&#xEAA3;"
                                Margin="12,12,12,0"
                                Grid.Row="3" />
            <controls:PopupInfo x:Name="Feature2"
                                Click="Feature2_Click"
                                Title="{CustomResource CocoonFeature2Title}"
                                Glyph="&#xEAF6;"
                                Margin="12,0,12,0"
                                Grid.Row="4" />
            <controls:PopupInfo x:Name="Feature3"
                                Click="Feature3_Click"
                                Title="{CustomResource CocoonFeature3Title}"
                                Glyph="&#xEAD8;"
                                Margin="12,0,12,0"
                                Grid.Row="5" />

            <controls:SettingsFooter x:Name="Footer"
                                     Click="Footer_Click"
                                     TextAlignment="Center"
                                     Margin="12,8,12,24"
                                     Grid.Row="6" />
        </Grid>
    </ScrollViewer>
</controls:ContentPopup>
