<controls:ContentPopup x:Class="Telegram.Views.Popups.MemberTagInfoPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:chats="using:Telegram.Controls.Chats"
                       xmlns:messages="using:Telegram.Controls.Messages"
                       mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:ProfilePicture x:Name="Photo"
                                 Size="72" />

        <TextBlock x:Name="TitleText"
                   Style="{StaticResource PopupTextBlockStyle}"
                   TextAlignment="Center"
                   Margin="0,8,0,0"
                   Grid.Row="1" />

        <RichTextBlock x:Name="Message"
                       TextAlignment="Center"
                       IsTextSelectionEnabled="False"
                       Margin="-8,4,-8,12"
                       Grid.Row="2" />

        <Grid ColumnSpacing="8"
              Margin="-4,0"
              Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid CornerRadius="8">
                <chats:ChatBackgroundControl x:Name="BackgroundControl1" />
                <Border SizeChanged="AlphaMask_SizeChanged"
                        Margin="-24,12,12,12">
                    <messages:MessageBubble x:Name="Message1" />
                </Border>
            </Grid>

            <Grid x:Name="Preview2"
                  CornerRadius="8"
                  Grid.Column="1">
                <chats:ChatBackgroundControl x:Name="BackgroundControl2" />
                <Border SizeChanged="AlphaMask_SizeChanged"
                        Margin="-24,12,12,12">
                    <messages:MessageBubble x:Name="Message2" />
                </Border>
            </Grid>
        </Grid>

        <TextBlock x:Name="CanEdit"
                   Text="{CustomResource CantEditTagAdmins}"
                   TextAlignment="Center"
                   Style="{StaticResource InfoCaptionTextBlockStyle}"
                   Margin="0,8,0,0"
                   Grid.Row="4" />
    </Grid>
</controls:ContentPopup>
