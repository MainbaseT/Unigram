<controls:ContentPopup x:Class="Telegram.Views.Popups.CreateChatPhotoPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:local="using:Telegram.Views.Popups"
                       xmlns:common="using:Telegram.Common"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:chats="using:Telegram.Controls.Chats"
                       xmlns:drawers="using:Telegram.Controls.Drawers"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:td="using:Telegram.Td.Api"
                       mc:Ignorable="d"
                       Title="{x:Null}"
                       PrimaryButtonText="Button1"
                       SecondaryButtonText="Button2"
                       PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
                       IsPrimaryButtonEnabled="{x:Bind ConvertEnabled(ViewModel.SelectedBackground, ViewModel.SelectedForeground), Mode=OneWay}"
                       Closing="OnClosing"
                       VerticalContentAlignment="Stretch"
                       Padding="0">

    <Grid Margin="0,0,0,-32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Width="128"
              Height="128"
              CornerRadius="60"
              Margin="0,8,0,8"
              Grid.Row="0">
            <chats:ChatBackgroundPreview x:Name="Renderer"
                                         Fill="{x:Bind ViewModel.SelectedBackground, Mode=OneWay}" />
            <controls:AnimatedImage x:Name="Icon"
                                    Tag="{x:Bind ConvertForeground(ViewModel.SelectedForeground), Mode=OneWay}"
                                    AutoPlay="True"
                                    FrameSize="128,128"
                                    DecodeFrameType="Logical"
                                    Width="128"
                                    Height="128" />

            <Ellipse Stroke="{ThemeResource NavigationViewContentGridBorderBrush}"
                     StrokeThickness="1" />
            <Path Fill="{ThemeResource ContentDialogBackground}"
                  StrokeThickness="0">
                <Path.Data>
                    <GeometryGroup>
                        <RectangleGeometry Rect="0,0,128,128" />
                        <EllipseGeometry Center="64,64"
                                         RadiusX="64"
                                         RadiusY="64" />
                    </GeometryGroup>
                </Path.Data>
            </Path>
        </Grid>

        <!--<TextBlock Text="{CustomResource ColorPickerBackground}"
                   Style="{StaticResource BaseTextBlockStyle}" />-->

        <ListView ItemsSource="{x:Bind ViewModel.Items}"
                  SelectedItem="{x:Bind ViewModel.SelectedBackground, Mode=TwoWay}"
                  Style="{StaticResource StaticListViewStyle}"
                  Padding="4,0,0,0"
                  Grid.Row="1">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="MinWidth"
                            Value="0" />
                    <Setter Property="MinHeight"
                            Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Grid CornerRadius="100"
                                      Margin="0,0,8,0">
                                    <ContentPresenter />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="td:BackgroundFill">
                    <chats:ChatBackgroundPreview Fill="{x:Bind}"
                                                 Width="31"
                                                 Height="31" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Pivot x:Name="Pivot"
               SelectionChanged="OnSelectionChanged"
               Style="{StaticResource HeaderlessPivotStyle}"
               Grid.Row="3">
            <PivotItem>
                <Grid x:Name="EmojisPanel"
                      x:Load="False">
                    <drawers:ChatPhotoEmojiDrawer x:Name="EmojisRoot"
                                                  ItemClick="Emojis_ItemClick"
                                                  ScrollingHostPadding="0,0,0,56" />
                    <controls:ScrollViewerScrim Background="{ThemeResource ContentDialogBackground}"
                                                ScrollingHost="{x:Bind EmojisRoot.ScrollingHost}"
                                                TopInset="0"
                                                BottomInset="56" />
                </Grid>
            </PivotItem>
            <PivotItem>
                <Grid x:Name="StickersPanel"
                      x:Load="False">
                    <drawers:StickerDrawer x:Name="StickersRoot"
                                           ScrollingHostPadding="0,0,0,56" />
                    <controls:ScrollViewerScrim Background="{ThemeResource ContentDialogBackground}"
                                                ScrollingHost="{x:Bind StickersRoot.ScrollingHost}"
                                                TopInset="0"
                                                BottomInset="56" />
                </Grid>
            </PivotItem>
        </Pivot>

        <Grid Grid.Row="2">
            <Border x:Name="NavigationSeparator" />

            <controls:TopNavView x:Name="Navigation"
                                 SelectionChanged="OnSelectionChanged"
                                 HorizontalAlignment="Center"
                                 Height="40">
                <controls:TopNavViewItem Content="{CustomResource AccDescrStickers}" />
                <controls:TopNavViewItem Content="{CustomResource Emoji}" />
            </controls:TopNavView>
        </Grid>
    </Grid>
</controls:ContentPopup>
