<controls:ContentPopup x:Class="Telegram.Views.Popups.DisableSharingPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:common="using:Telegram.Common"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Padding="0"
                       IsDismissButtonVisible="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:AnimatedImage Source="ms-appx:///Assets/Animations/DisableSharing.tgs"
                                    IsCachingEnabled="False"
                                    AutoPlay="True"
                                    FrameSize="120,120"
                                    DecodeFrameType="Logical"
                                    LoopCount="1"
                                    Width="120"
                                    Height="120"
                                    Margin="0,12,0,12" />

            <TextBlock Text="{CustomResource DisableSharingInfoHeader}"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="12,0,12,8"
                       Grid.Row="1" />

            <controls:PopupInfo Title="{CustomResource DisableSharingInfoHeader1}"
                                Subtitle="{CustomResource DisableSharingInfoText1}"
                                Glyph="&#xEAFB;"
                                Margin="12,12,12,0"
                                Grid.Row="3" />
            <controls:PopupInfo Title="{CustomResource DisableSharingInfoHeader2}"
                                Subtitle="{CustomResource DisableSharingInfoText2}"
                                Glyph="&#xEAFC;"
                                Margin="12,0,12,0"
                                Grid.Row="4" />
            <controls:PopupInfo Title="{CustomResource DisableSharingInfoHeader3}"
                                Subtitle="{CustomResource DisableSharingInfoText3}"
                                Glyph="&#xEAF9;"
                                Margin="12,0,12,0"
                                Grid.Row="5" />
        </Grid>
    </ScrollViewer>
</controls:ContentPopup>
