<controls:ContentPopup x:Class="Telegram.Views.Popups.JoinChatPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       Title="{x:Null}"
                       Padding="24,0,24,24"
                       mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:ProfilePicture x:Name="Photo"
                                     Size="96"
                                     Margin="0,24,0,8" />
            <Grid HorizontalAlignment="Center"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:CustomEmojiIcon x:Name="BotVerified"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,4,4" />

                <TextBlock x:Name="Title"
                           Style="{StaticResource PopupTextBlockStyle}"
                           TextAlignment="Center"
                           VerticalAlignment="Bottom" />

                <controls:IdentityIcon x:Name="Identity"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,0,4"
                                       Grid.Column="1" />

            </Grid>
            <TextBlock x:Name="Subtitle"
                       Style="{StaticResource InfoCaptionTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="12,0,12,0"
                       Grid.Row="2" />

            <TextBlock x:Name="Description"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="12,8,12,0"
                       Grid.Row="3" />
        </Grid>

        <controls:RecentUserHeads x:Name="Participants"
                                  BorderBrush="{ThemeResource ContentDialogTopOverlaySolid}"
                                  ItemSize="48"
                                  ItemOverlap="16"
                                  RecentUserHeadChanged="Participants_RecentUserHeadChanged"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,4"
                                  Grid.Row="2" />

        <TextBlock x:Name="JoinRequestInfo"
                   Text="{CustomResource RequestToJoinChannelDescription}"
                   Style="{StaticResource BodyTextBlockStyle}"
                   TextAlignment="Center"
                   Grid.Row="3" />
    </Grid>
</controls:ContentPopup>
