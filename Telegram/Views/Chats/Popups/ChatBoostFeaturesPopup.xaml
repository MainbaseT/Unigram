<controls:ContentPopup x:Class="Telegram.Views.Chats.Popups.ChatBoostFeaturesPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:local="using:Telegram.Views.Chats.Popups"
                       xmlns:common="using:Telegram.Common"
                       xmlns:cells="using:Telegram.Controls.Cells"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       mc:Ignorable="d"
                       Padding="0"
                       IsDismissButtonVisible="True"
                       PrimaryButtonStyle="{StaticResource PremiumButtonStyle}"
                       PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
                       ButtonsLayout="Vertical">

    <Grid>
        <ListView x:Name="ScrollingHost"
                  ContainerContentChanging="OnContainerContentChanging"
                  SelectionMode="None"
                  Padding="24,0,24,12">
            <ListView.Header>
                <Grid Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                          CornerRadius="4"
                          VerticalAlignment="Bottom">
                        <TextBlock TextAlignment="Left"
                                   FontWeight="SemiBold"
                                   Margin="8,4,8,5" />
                    </Grid>

                    <controls:PremiumProgressBar x:Name="Progress"
                                                 Background="{StaticResource PremiumLinearGradientBrush}"
                                                 Glyph="&#xEA3A;"
                                                 MaximumVisibility="Collapsed"
                                                 Margin="0,24,0,0" />

                    <TextBlock x:Name="TitleLabel"
                               Text="{CustomResource StarRatingTitle}"
                               Style="{StaticResource PopupTextBlockStyle}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,8,0,4"
                               Grid.Row="1" />
                    <TextBlock x:Name="Description"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,0,0,8"
                               Grid.Row="2" />

                    <Grid x:Name="CopyRoot"
                          Grid.Row="3">
                        <Button Click="CopyLink_Click"
                                HorizontalAlignment="Stretch"
                                Padding="24,5,24,6">
                            <TextBlock x:Name="Link"
                                       TextTrimming="CharacterEllipsis" />
                        </Button>
                        <TextBlock Text="&#xEAC9;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="20"
                                   Foreground="{ThemeResource AccentButtonBackground}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <cells:ChatBoostFeaturesCell />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <controls:ScrollViewerScrim Background="{ThemeResource ContentDialogTopOverlaySolid}"
                                    ScrollingHost="{x:Bind ScrollingHost}"
                                    BottomInset="0" />
    </Grid>
</controls:ContentPopup>
