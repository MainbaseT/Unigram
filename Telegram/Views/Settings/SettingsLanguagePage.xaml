<local:HostedPage x:Class="Telegram.Views.Settings.SettingsLanguagePage"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:controls="using:Telegram.Controls"
                  xmlns:local="using:Telegram.Views"
                  mc:Ignorable="d"
                  NavigationMode="Root">

    <Grid Background="{ThemeResource SettingsPageBackground}">
        <controls:TableListView x:Name="ScrollingHost"
                                ItemsSource="{x:Bind ViewModel.Items}"
                                ChoosingItemContainer="OnChoosingItemContainer"
                                ContainerContentChanging="OnContainerContentChanging"
                                SelectionMode="None">
            <ListView.Header>
                <controls:SettingsPanel IsHeader="True">
                    <controls:HeaderedControl Header="{CustomResource TranslateMessages}"
                                              Footer="{x:Bind ConvertTranslateInfo(ViewModel.TranslateMessages), Mode=OneWay}">
                        <CheckBox IsChecked="{x:Bind ViewModel.TranslateMessages, Mode=TwoWay}"
                                  Content="{CustomResource ShowTranslateButton}"
                                  Style="{StaticResource SettingsCheckBoxStyle}" />

                        <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeTranslateChat}"
                                                   IsFaux="True"
                                                   IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                                   IsChecked="{x:Bind ViewModel.TranslateChats, Mode=OneWay}"
                                                   Content="{CustomResource ShowTranslateChatButton}"
                                                   Style="{StaticResource SettingsCheckBoxStyle}" />
                            <TextBlock x:Name="TranslateChatsLock"
                                       x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                       Text="&#xEA25;"
                                       Foreground="{ThemeResource SystemControlDisabledChromeDisabledLowBrush}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20"
                                       Padding="20,12,0,0"
                                       IsHitTestVisible="False" />
                        </Grid>

                        <controls:SettingsButton Content="{CustomResource DoNotTranslate}"
                                                 Badge="{x:Bind ViewModel.DoNotTranslate, Mode=OneWay}"
                                                 Click="{x:Bind ViewModel.ChangeDoNotTranslate}"
                                                 Visibility="{x:Bind ConvertDoNotTranslate(ViewModel.TranslateMessages, ViewModel.TranslateChats), Mode=OneWay}"
                                                 Glyph="&#xE98B;" />
                    </controls:HeaderedControl>

                    <StackPanel>
                        <TextBlock Text="{CustomResource Language}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   Margin="24,16,24,8" />

                        <Grid HorizontalAlignment="Left"
                              Margin="24,0,24,2"
                              Width="280">
                            <TextBox x:Name="SearchField"
                                     Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="{CustomResource Search}"
                                     PreventKeyboardDisplayOnProgrammaticFocus="True"
                                     Padding="34,5,6,6"
                                     InputScope="Search" />

                            <controls:GlyphButton Glyph="&#xE721;"
                                                  FontSize="16"
                                                  Width="36"
                                                  Height="32"
                                                  IsTabStop="False"
                                                  AutomationProperties.AccessibilityView="Raw"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </controls:SettingsPanel>
            </ListView.Header>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <Style TargetType="ListViewHeaderItem">
                            <Setter Property="Margin"
                                    Value="0" />
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="MinHeight"
                                    Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewHeaderItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Height="32" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <RadioButton Style="{StaticResource SettingsRadioButtonStyle}"
                                 GroupName="Languages"
                                 CornerRadius="4"
                                 BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock VerticalAlignment="Bottom"
                                       Style="{StaticResource BaseTextBlockStyle}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource InfoBodyTextBlockStyle}"
                                       VerticalAlignment="Top"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       Grid.Row="1" />
                        </Grid>
                    </RadioButton>
                </DataTemplate>
            </ListView.ItemTemplate>
            <!--<ListView.Header>
                <Border Height="16"/>
            </ListView.Header>-->
            <ListView.Footer>
                <Border Height="60" />
            </ListView.Footer>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel AreStickyGroupHeadersEnabled="False"
                                     Margin="24,0" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </controls:TableListView>
    </Grid>
</local:HostedPage>
