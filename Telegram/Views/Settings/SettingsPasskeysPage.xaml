<local:HostedPage x:Class="Telegram.Views.Settings.SettingsPasskeysPage"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:controls="using:Telegram.Controls"
                  xmlns:local="using:Telegram.Views"
                  mc:Ignorable="d">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition>
                <SlideNavigationTransitionInfo Effect="FromRight" />
            </NavigationThemeTransition>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Background="{ThemeResource SettingsPageBackground}">
        <controls:TableListView x:Name="ScrollingHost"
                                ItemsSource="{x:Bind ViewModel.Items}"
                                ChoosingItemContainer="OnChoosingItemContainer"
                                ContainerContentChanging="OnContainerContentChanging"
                                CornerRadius="0,0,4,4"
                                SelectionMode="None">
            <ListView.Header>
                <controls:SettingsPanel>
                    <controls:SettingsHeadline Source="ms-appx:///Assets/Animations/Passkey.tgs"
                                               Text="{CustomResource PasskeyTopInfo}" />
                </controls:SettingsPanel>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          Background="{ThemeResource SettingsItemBackground}"
                          Padding="12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid CornerRadius="8"
                              Margin="0,6,10,6"
                              Grid.RowSpan="2">
                            <TextBlock Text="&#xE192;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <controls:AnimatedImage x:Name="Animated"
                                                    Width="36"
                                                    Height="36"
                                                    FrameSize="36,36"
                                                    DecodeFrameType="Logical" />
                        </Grid>

                        <TextBlock x:Name="TitleLabel"
                                   FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom" />
                        <TextBlock x:Name="SubtitleLabel"
                                   VerticalAlignment="Top"
                                   Style="{StaticResource InfoCaptionTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Grid.Column="1"
                                   Grid.Row="1"
                                   MaxLines="1" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <controls:SettingsPanel IsFooter="True"
                                        Margin="0,2,0,0">
                    <controls:HeaderedControl IsFooterLink="True"
                                              Footer="{CustomResource PasskeyInfo}"
                                              Click="Info_Click"
                                              Padding="0">
                        <controls:SettingsButton Content="{CustomResource PasskeyAdd}"
                                                 Click="{x:Bind ViewModel.Create}"
                                                 Visibility="{x:Bind ViewModel.CanAdd, Mode=OneWay}"
                                                 Glyph="&#xEAF5;" />
                    </controls:HeaderedControl>
                </controls:SettingsPanel>
            </ListView.Footer>
        </controls:TableListView>
    </Grid>
</local:HostedPage>
