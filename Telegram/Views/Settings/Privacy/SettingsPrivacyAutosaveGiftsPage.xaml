<local:HostedPage x:Class="Telegram.Views.Settings.Privacy.SettingsPrivacyAutosaveGiftsPage"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="using:Telegram.Views"
                  xmlns:controls="using:Telegram.Controls"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  mc:Ignorable="d">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition>
                <SlideNavigationTransitionInfo Effect="FromRight" />
            </NavigationThemeTransition>
        </TransitionCollection>
    </Page.Transitions>

    <local:HostedPage.Action>
        <Button Content="{CustomResource Done}"
                Click="{x:Bind ViewModel.Continue}"
                Style="{StaticResource AccentButtonStyle}"
                Visibility="{x:Bind ViewModel.HasChanged, Mode=OneWay}" />
    </local:HostedPage.Action>

    <Grid Background="{ThemeResource SettingsPageBackground}">
        <ScrollViewer x:Name="ScrollingHost"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <controls:SettingsPanel>
                <controls:HeaderedControl x:Name="ShowIconRoot">
                    <CheckBox Content="{CustomResource PrivacyGiftsShowIcon}"
                              IsChecked="{x:Bind ViewModel.ShowIcon, Mode=TwoWay}"
                              Style="{StaticResource SettingsCheckBoxStyle}" />
                </controls:HeaderedControl>

                <controls:HeaderedControl Header="{CustomResource PrivacyGiftsTitle}"
                                          Footer="{CustomResource PrivacyGiftsInfo}">
                    <controls:PrivacyRadioButton Content="{CustomResource LastSeenEverybody}"
                                                 Value="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                                                 Type="AllowAll"
                                                 Style="{StaticResource SettingsRadioButtonStyle}" />

                    <controls:PrivacyRadioButton Content="{CustomResource LastSeenContacts}"
                                                 Value="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                                                 Type="AllowContacts"
                                                 Style="{StaticResource SettingsRadioButtonStyle}" />

                    <controls:PrivacyRadioButton Content="{CustomResource LastSeenNobody}"
                                                 Value="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                                                 Type="DisallowAll"
                                                 Style="{StaticResource SettingsRadioButtonStyle}" />
                </controls:HeaderedControl>

                <controls:HeaderedControl Header="{CustomResource AddExceptions}"
                                          Footer="{CustomResource CustomShareGiftsInfo}">
                    <controls:SettingsButton Content="{CustomResource AlwaysShareWith}"
                                             Click="{x:Bind ViewModel.Always}"
                                             Visibility="{x:Bind ConvertAlways(ViewModel.SelectedItem), Mode=OneWay}"
                                             Badge="{x:Bind ViewModel.AllowedBadge, Mode=OneWay}"
                                             Glyph="&#xF164;" />

                    <controls:SettingsButton Content="{CustomResource NeverShareWith}"
                                             Click="{x:Bind ViewModel.Never}"
                                             Visibility="{x:Bind ConvertNever(ViewModel.SelectedItem), Mode=OneWay}"
                                             Badge="{x:Bind ViewModel.RestrictedBadge, Mode=OneWay}"
                                             Glyph="&#xF166;" />
                </controls:HeaderedControl>

                <controls:HeaderedControl Header="{CustomResource PrivacyGiftsTypeHeader}"
                                          Footer="{CustomResource PrivacyGiftsTypeInfo}">
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeAllowLimited}"
                                               IsFaux="True"
                                               IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                               IsChecked="{x:Bind ViewModel.AllowLimited, Mode=OneWay}"
                                               Content="{CustomResource PrivacyGiftsTypeLimited}"
                                               Style="{StaticResource SettingsCheckBoxStyle}" />
                        <Border x:Name="AllowLimitedLock"
                                x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                Background="{ThemeResource CheckBoxCheckBackgroundFillChecked}"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,12,0,0"
                                Padding="2"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xE9BE;"
                                       Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Border>
                    </Grid>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeAllowUnlimited}"
                                               IsFaux="True"
                                               IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                               IsChecked="{x:Bind ViewModel.AllowUnlimited, Mode=OneWay}"
                                               Content="{CustomResource PrivacyGiftsTypeUnlimited}"
                                               Style="{StaticResource SettingsCheckBoxStyle}" />
                        <Border x:Name="AllowUnlimitedLock"
                                x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                Background="{ThemeResource CheckBoxCheckBackgroundFillChecked}"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,12,0,0"
                                Padding="2"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xE9BE;"
                                       Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Border>
                    </Grid>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeAllowUnique}"
                                               IsFaux="True"
                                               IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                               IsChecked="{x:Bind ViewModel.AllowUnique, Mode=OneWay}"
                                               Content="{CustomResource PrivacyGiftsTypeUnique}"
                                               Style="{StaticResource SettingsCheckBoxStyle}" />
                        <Border x:Name="AllowUniqueLock"
                                x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                Background="{ThemeResource CheckBoxCheckBackgroundFillChecked}"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,12,0,0"
                                Padding="2"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xE9BE;"
                                       Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Border>
                    </Grid>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeAllowFromChannels}"
                                               IsFaux="True"
                                               IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                               IsChecked="{x:Bind ViewModel.AllowFromChannels, Mode=OneWay}"
                                               Content="{CustomResource PrivacyGiftsTypeFromChannels}"
                                               Style="{StaticResource SettingsCheckBoxStyle}" />
                        <Border x:Name="AllowFromChannelsLock"
                                x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                Background="{ThemeResource CheckBoxCheckBackgroundFillChecked}"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,12,0,0"
                                Padding="2"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xE9BE;"
                                       Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Border>
                    </Grid>
                    <Grid BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <controls:FauxCheckBox Click="{x:Bind ViewModel.ChangeAllowPremium}"
                                               IsFaux="True"
                                               IsChevronVisible="{x:Bind ViewModel.IsPremium, Mode=OneWay}"
                                               IsChecked="{x:Bind ViewModel.AllowPremium, Mode=OneWay}"
                                               Content="{CustomResource PrivacyGiftsTypePremium}"
                                               Style="{StaticResource SettingsCheckBoxStyle}" />
                        <Border x:Name="AllowPremiumLock"
                                x:Load="{x:Bind ViewModel.IsPremium, Mode=OneWay, Converter={StaticResource BooleanNegationConverter}}"
                                Background="{ThemeResource CheckBoxCheckBackgroundFillChecked}"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,12,0,0"
                                Padding="2"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xE9BE;"
                                       Foreground="{ThemeResource CheckBoxCheckGlyphForegroundChecked}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Border>
                    </Grid>
                </controls:HeaderedControl>
            </controls:SettingsPanel>
        </ScrollViewer>
    </Grid>
</local:HostedPage>
