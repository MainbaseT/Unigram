<controls:ContentPopup x:Class="Telegram.Views.Settings.SettingsPasskeysIntroPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:common="using:Telegram.Common"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Padding="24,12,24,12"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:AnimatedImage Source="ms-appx:///Assets/Animations/Passkey.tgs"
                                IsCachingEnabled="False"
                                AutoPlay="True"
                                FrameSize="96,96"
                                DecodeFrameType="Logical"
                                LoopCount="1"
                                Width="96"
                                Height="96"
                                Margin="0,0,0,12" />

        <TextBlock Text="{CustomResource PasskeyFeatureTitle}"
                   Style="{StaticResource PopupTextBlockStyle}"
                   TextAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,0,0,8"
                   Grid.Row="1" />

        <TextBlock common:TextBlockHelper.Markdown="{CustomResource PasskeyFeatureSubtitle}"
                   Style="{StaticResource BodyTextBlockStyle}"
                   TextAlignment="Center"
                   Grid.Row="2" />

        <controls:SettingsButton Content="{CustomResource PasskeyFeature1Title}"
                                 Badge="{CustomResource PasskeyFeature1Subtitle}"
                                 Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                 Glyph="&#xE192;"
                                 Margin="-12,12,-12,0"
                                 IsHitTestVisible="False"
                                 Grid.Row="3" />
        <controls:SettingsButton Content="{CustomResource PasskeyFeature2Title}"
                                 Badge="{CustomResource PasskeyFeature2Subtitle}"
                                 Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                 Glyph="&#xEAF1;"
                                 Margin="-12,-8,-12,0"
                                 IsHitTestVisible="False"
                                 Grid.Row="4" />
        <controls:SettingsButton Content="{CustomResource PasskeyFeature3Title}"
                                 Badge="{CustomResource PasskeyFeature3Subtitle}"
                                 Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                 Glyph="&#xE72E;"
                                 Margin="-12,-8,-12,0"
                                 IsHitTestVisible="False"
                                 Grid.Row="5" />

    </Grid>
</controls:ContentPopup>
