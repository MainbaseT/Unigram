<profile:ProfileTabPage x:Class="Telegram.Views.Settings.SettingsProfileColorProfileTabPage"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:common="using:Telegram.Common"
                        xmlns:controls="using:Telegram.Controls"
                        xmlns:cells="using:Telegram.Controls.Cells"
                        xmlns:popups="using:Telegram.Views.Popups"
                        xmlns:profile="using:Telegram.Views.Profile"
                        mc:Ignorable="d"
                        ItemsSource="{x:Bind ViewModel.ItemsView}">

    <Grid>
        <controls:SelectGridView x:Name="ScrollingHost"
                                 SelectionMode="Single"
                                 SelectedItem="{x:Bind ViewModel.SelectedItemView, Mode=TwoWay}"
                                 ChoosingItemContainer="OnChoosingItemContainer"
                                 ContainerContentChanging="OnContainerContentChanging"
                                 Padding="24,0,16,8"
                                 common:FluidGridView.Padding="0,0,4,0"
                                 common:FluidGridView.MaxLength="1008">
            <!--<common:SelectedItemsBinder.Attached>
                <common:SelectedItemsBinder SelectionMode="Auto"
                                            SelectedItems="{x:Bind ViewModel.SelectedItems}" />
            </common:SelectedItemsBinder.Attached>-->
            <common:FluidGridView.Triggers>
                <common:FluidGridViewTrigger MinLength="0"
                                             RowsOrColumns="2" />
                <common:FluidGridViewTrigger MinLength="360"
                                             RowsOrColumns="3" />
                <common:FluidGridViewTrigger MinLength="600"
                                             RowsOrColumns="4" />
                <common:FluidGridViewTrigger MinLength="800"
                                             RowsOrColumns="5" />
            </common:FluidGridView.Triggers>
            <GridView.Template>
                <ControlTemplate TargetType="GridView">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ItemsPresenter Header="{TemplateBinding Header}"
                                        HeaderTemplate="{TemplateBinding HeaderTemplate}"
                                        HeaderTransitions="{TemplateBinding HeaderTransitions}"
                                        Footer="{TemplateBinding Footer}"
                                        FooterTemplate="{TemplateBinding FooterTemplate}"
                                        FooterTransitions="{TemplateBinding FooterTransitions}"
                                        Padding="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </GridView.Template>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem"
                       BasedOn="{StaticResource DefaultGridViewItemStyle}">
                    <Setter Property="Margin"
                            Value="0,4,4,0" />
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.Header>
                <controls:SettingsPanel IsHeader="True"
                                        Margin="0,64,0,0">
                    <popups:ChooseProfileColorView x:Name="View"
                                                   SelectedAccentColor="{x:Bind ViewModel.SelectedAccentColor, Mode=TwoWay}"
                                                   SelectedCustomEmojiId="{x:Bind ViewModel.SelectedCustomEmojiId, Mode=TwoWay}"
                                                   SelectedEmojiStatus="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                                                   Margin="-24,0,-16,0" />

                    <controls:TopNavView x:Name="Navigation"
                                         ItemsSource="{x:Bind ViewModel.Collections}"
                                         SelectedItem="{x:Bind ViewModel.SelectedCollection, Mode=TwoWay}"
                                         ContainerContentChanging="Navigation_ContainerContentChanging"
                                         HorizontalAlignment="Center"
                                         Height="40"
                                         Margin="0,0,0,-4">
                        <controls:TopNavView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <controls:CustomEmojiIcon Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" />
                                </Grid>
                            </DataTemplate>
                        </controls:TopNavView.ItemTemplate>
                        <controls:TopNavView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal"
                                                 HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </controls:TopNavView.ItemsPanel>
                        <controls:TopNavView.ItemContainerStyle>
                            <Style TargetType="controls:TopNavViewItem">
                                <Setter Property="HorizontalAlignment"
                                        Value="Stretch" />
                                <Setter Property="VerticalAlignment"
                                        Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalContentAlignment"
                                        Value="Center" />
                                <Setter Property="UseSystemFocusVisuals"
                                        Value="True" />
                                <Setter Property="FocusVisualMargin"
                                        Value="-3,5" />
                                <Setter Property="CornerRadius"
                                        Value="12" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="controls:TopNavViewItem">
                                            <Grid x:Name="ContentBorder"
                                                  Background="Transparent">
                                                <ContentPresenter x:Name="ContentPresenter"
                                                                  Grid.Column="1"
                                                                  Margin="12,5,12,6"
                                                                  TextWrapping="NoWrap"
                                                                  Foreground="{TemplateBinding Foreground}"
                                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  Content="{TemplateBinding Content}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                  VerticalAlignment="Center"
                                                                  AutomationProperties.AccessibilityView="Raw"
                                                                  Canvas.ZIndex="1" />
                                                <Grid x:Name="SelectionIndicatorGrid"
                                                      Margin="0,8,0,8"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch">
                                                    <Rectangle x:Name="SelectionIndicator"
                                                               Fill="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                                                               Opacity="0"
                                                               RadiusX="12"
                                                               RadiusY="12" />
                                                </Grid>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </controls:TopNavView.ItemContainerStyle>
                    </controls:TopNavView>
                </controls:SettingsPanel>
            </GridView.Header>
            <GridView.Footer>
                <Border Margin="0,0,0,60">
                    <Grid x:Name="EmptyState"
                          Visibility="{x:Bind ViewModel.IsEmptyView, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid VerticalAlignment="Center"
                              MaxWidth="1000"
                              Margin="24,0"
                              Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <controls:AnimatedImage Source="ms-appx:///Assets/Animations/ProfileColor.tgs"
                                                    IsCachingEnabled="False"
                                                    AutoPlay="True"
                                                    FrameSize="140,140"
                                                    DecodeFrameType="Logical"
                                                    LoopCount="1"
                                                    Width="140"
                                                    Height="140"
                                                    Margin="0,48,0,12" />
                            <TextBlock common:TextBlockHelper.Markdown="{CustomResource Gift2PeerColorProfileEmptyTitle}"
                                       Style="{StaticResource InfoBodyTextBlockStyle}"
                                       TextAlignment="Center"
                                       Margin="12,4,12,0"
                                       Grid.Row="1" />

                            <Button Click="{x:Bind ViewModel.Browse}"
                                    Content="{CustomResource Gift2PeerColorEmptyButton}"
                                    Style="{StaticResource AccentTextButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0"
                                    Grid.Row="2" />
                        </Grid>
                    </Grid>
                </Border>
            </GridView.Footer>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <cells:ReceivedGiftCell />
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaxWidth="1008" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </controls:SelectGridView>
    </Grid>
</profile:ProfileTabPage>
