                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="Chevron"
                                  Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Margin="20,12,0,12"
                                  Height="{StaticResource CheckBoxSize}"
                                  Width="{StaticResource CheckBoxSize}">
                                <Rectangle x:Name="NormalRectangle"
                                           Fill="{ThemeResource CheckBoxCheckBackgroundFillUnchecked}"
                                           Stroke="{ThemeResource CheckBoxCheckBackgroundStrokeUnchecked}"
                                           StrokeThickness="{StaticResource CheckBoxBorderThickness}"
                                           UseLayoutRounding="False"
                                           Height="{StaticResource CheckBoxSize}"
                                           Width="{StaticResource CheckBoxSize}"
                                           RadiusX="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}"
                                           RadiusY="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" />
                                <muxc:AnimatedIcon x:Name="CheckGlyph"
                                                   Foreground="{ThemeResource CheckBoxCheckGlyphForegroundUnchecked}"
                                                   Margin="0,1,0,-1">
                                    <animatedvisuals:AnimatedAcceptVisualSource />
                                    <muxc:AnimatedIcon.FallbackIconSource>
                                        <muxc:FontIconSource x:Name="DownLevelCheckGlyph"
                                                             FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                             Glyph="{StaticResource CheckBoxCheckedGlyph}"
                                                             FontSize="{StaticResource CheckBoxGlyphSize}" />
                                    </muxc:AnimatedIcon.FallbackIconSource>
                                </muxc:AnimatedIcon>

                            </Grid>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="1"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              Content="{TemplateBinding Content}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              AutomationProperties.AccessibilityView="Raw"
                                              TextWrapping="Wrap" />
                        </Grid>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource SettingsPageBackground}">
        <controls:TableListView x:Name="ScrollingHost"
                                ItemsSource="{x:Bind ViewModel.Statistics.ByChat, Mode=OneWay}"
                                ItemClick="ListView_ItemClick"
                                IsItemClickEnabled="True"
                                SelectionMode="None"
                                ContainerContentChanging="OnContainerContentChanging">
            <ListView.Header>
                <controls:SettingsPanel>
                    <Grid MaxWidth="1000"
                          Margin="24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Width="140"
                              Height="140"
                              Margin="0,16,0,16">
                            <controls:StorageChart x:Name="Chart"
                                                   Items="{x:Bind ViewModel.ItemsView, Mode=OneWay}"
                                                   Width="120"
                                                   Height="120" />

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SizeLabel"
                                           Style="{StaticResource PopupTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           TextAlignment="Center"
                                           Margin="0,0,0,-4" />
                                <TextBlock x:Name="UnitLabel"
                                           Style="{StaticResource InfoBodyTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <controls:ProgressRingIndeterminate x:Name="Ring"
                                                            x:Load="False"
                                                            Fill="{ThemeResource ProgressRingBackgroundThemeBrush}"
                                                            Stroke="{ThemeResource ProgressRingForegroundThemeBrush}"
                                                            StrokeThickness="8"
                                                            Width="120"
                                                            Height="120" />

                        <TextBlock x:Name="Subtitle"
                                   common:TextBlockHelper.Markdown="{CustomResource StorageUsageCalculating}"
                                   Style="{StaticResource InfoBodyTextBlockStyle}"
                                   TextAlignment="Center"
                                   Margin="12,0,12,0"
                                   MaxWidth="480"
                                   Grid.Row="1" />
                    </Grid>

                    <StackPanel Visibility="{x:Bind ViewModel.ItemsView, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <controls:HeaderedControl ItemsSource="{x:Bind ViewModel.ItemsView, Mode=OneWay}"
                                                  CornerRadius="8,8,0,0">
                            <controls:HeaderedControl.ItemTemplate>
                                <DataTemplate x:DataType="controls:StorageChartItem">
                                    <controls:FauxCheckBox Click="StorageChartItem_Checked"
                                                           Style="{StaticResource SettingsCheckBoxStyle}"
                                                           IsChecked="{x:Bind IsVisible}"
                                                           IsFaux="True">
                                        <CheckBox.Background>
                                            <SolidColorBrush Color="{x:Bind Stroke}" />
                                        </CheckBox.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Bind Name}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind TotalBytes, Mode=OneWay, Converter={StaticResource FileSizeConverter}, ConverterParameter=allowGb}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource SystemControlDisabledChromeDisabledLowBrush}"
                                                       VerticalAlignment="Bottom"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Margin="4,0,0,0"
                                                       MaxLines="1" />
                                        </StackPanel>
                                    </controls:FauxCheckBox>
                                </DataTemplate>
                            </controls:HeaderedControl.ItemTemplate>
                        </controls:HeaderedControl>
                        <controls:HeaderedControl Footer="{CustomResource StorageUsageInfo}"
                                                  BorderThickness="1,0,1,1"
                                                  CornerRadius="0,0,8,8"
                                                  Padding="0">
                            <Grid Background="{ThemeResource SettingsItemBackground}"
                                  Padding="12,8">

                                <Button Click="{x:Bind ViewModel.ClearCache}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        HorizontalAlignment="Stretch">
                                    <Grid Padding="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{CustomResource ClearMediaCache}" />
                                        <TextBlock Text="{x:Bind ViewModel.Statistics.Size, Mode=OneWay, Converter={StaticResource FileSizeConverter}, ConverterParameter=allowGb}"
                                                   Opacity="0.6"
                                                   Margin="4,0,0,0"
                                                   Grid.Column="1" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </controls:HeaderedControl>
                    </StackPanel>

                    <controls:HeaderedControl x:Name="KeepMediaPanel"
                                              Header="{CustomResource KeepMedia}"
                                              Footer="{CustomResource KeepMediaInfo}"
                                              Background="{ThemeResource SettingsItemBackground}">
                        <Grid x:Name="KeepMediaTicks"
                              Padding="12,6,12,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Slider x:Name="KeepMedia"
                                    Value="{x:Bind ConvertKeepMedia(ViewModel.KeepMedia), Mode=TwoWay, BindBack=ConvertKeepMediaBack}"
                                    Maximum="3"
                                    Minimum="0"
                                    SmallChange="1"
                                    LargeChange="1"
                                    StepFrequency="1"
                                    TickFrequency="1"
                                    TickPlacement="Outside"
                                    IsThumbToolTipEnabled="False"
                                    Grid.Row="1" />
                        </Grid>
                    </controls:HeaderedControl>

                    <controls:HeaderedControl>
                        <controls:SettingsButton Content="{CustomResource LocalDatabase}"
                                                 Badge="{x:Bind ViewModel.StatisticsFast.DatabaseSize, Mode=OneWay, Converter={StaticResource FileSizeConverter}, ConverterParameter=allowGb}" />
                        <controls:SettingsButton Click="{x:Bind ViewModel.ClearCache}"
                                                 Content="{CustomResource ClearMediaCache}"
                                                 Badge="{x:Bind ViewModel.Statistics.Size, Mode=OneWay, Converter={StaticResource FileSizeConverter}, ConverterParameter=allowGb}"
                                                 IsEnabled="{x:Bind ConvertEnabled(ViewModel.Statistics), Mode=OneWay}" />
                    </controls:HeaderedControl>
                </controls:SettingsPanel>
            </ListView.Header>
            <ListView.Footer>
                <Border Height="32" />
            </ListView.Footer>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <cells:ProfileCell Background="{ThemeResource SettingsItemBackground}"
                                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </controls:TableListView>
    </Grid>
</local:HostedPage>