<Page x:Class="Telegram.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:icons="using:Telegram.Assets.Icons"
      xmlns:controls="using:Telegram.Controls"
      mc:Ignorable="d">

    <Grid>
        <ScrollViewer x:Name="ScrollingHost"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      Grid.Row="1">
            <StackPanel Padding="0,0,0,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <HyperlinkButton Click="Photo_Click"
                                     Style="{StaticResource EmptyHyperlinkButtonStyle}"
                                     AutomationProperties.Name="{CustomResource AccDescrProfilePicture}"
                                     Height="48"
                                     Width="48"
                                     Margin="12,8"
                                     Grid.RowSpan="2">
                        <controls:ProfilePicture x:Name="Photo"
                                                 Height="48"
                                                 Width="48" />
                    </HyperlinkButton>

                    <Grid VerticalAlignment="Bottom"
                          HorizontalAlignment="Left"
                          Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <controls:CustomEmojiIcon x:Name="BotVerified"
                                                  Visibility="Collapsed"
                                                  VerticalAlignment="Bottom"
                                                  Margin="0,-2,4,-2" />

                        <TextBlock x:Name="Title"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{ThemeResource EmojiThemeFontFamily}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   Grid.Column="1" />

                        <controls:IdentityIcon x:Name="Identity"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,0"
                                               Grid.Column="2" />
                    </Grid>
                    <TextBlock x:Name="Subtitle"
                               Text="{CustomResource Online}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlDisabledChromeDisabledLowBrush}"
                               VerticalAlignment="Top"
                               Grid.Row="1"
                               Grid.Column="1" />

                    <controls:GlyphButton Content="&#xEACA;"
                                          Click="{x:Bind ViewModel.ShareUsername}"
                                          Foreground="{ThemeResource SystemColorControlAccentBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,0,0"
                                          CornerRadius="20"
                                          Grid.RowSpan="2"
                                          Grid.Column="2" />
                </Grid>

                <Rectangle Fill="{ThemeResource NavigationViewItemSeparatorForeground}"
                           Margin="12,2"
                           Height="1" />

                <controls:TopNavView x:Name="Navigation"
                                     Orientation="Vertical"
                                     Height="Auto">
                    <controls:TopNavView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </controls:TopNavView.ItemsPanel>
                    <controls:TopNavView.ItemContainerStyle>
                        <Style TargetType="controls:TopNavViewItem">
                            <Setter Property="HorizontalAlignment"
                                    Value="Stretch" />
                            <Setter Property="VerticalAlignment"
                                    Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="UseSystemFocusVisuals"
                                    Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="controls:TopNavViewItem">
                                        <Grid Background="Transparent">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal" />
                                                    <VisualState x:Name="PointerOver" />
                                                    <VisualState x:Name="Pressed" />
                                                    <VisualState x:Name="Selected">
                                                        <VisualState.Setters>
                                                            <Setter Target="LayoutRoot.Background"
                                                                    Value="{ThemeResource NavigationViewItemBackgroundSelected}" />
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="PointerOverSelected">
                                                        <VisualState.Setters>
                                                            <Setter Target="LayoutRoot.Background"
                                                                    Value="{ThemeResource NavigationViewItemBackgroundSelectedPointerOver}" />
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="PressedSelected" />
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                            <Border x:Name="LayoutRoot"
                                                    Margin="4,2"
                                                    CornerRadius="4" />
                                            <ContentPresenter x:Name="ContentPresenter"
                                                              Grid.Column="1"
                                                              Margin="0"
                                                              TextWrapping="NoWrap"
                                                              Foreground="{TemplateBinding Foreground}"
                                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              Content="{TemplateBinding Content}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                              VerticalAlignment="Center"
                                                              AutomationProperties.AccessibilityView="Raw" />
                                            <Grid x:Name="SelectionIndicatorGrid"
                                                  Margin="4,4,0,4"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center">
                                                <Rectangle x:Name="SelectionIndicator"
                                                           Width="3"
                                                           Height="16"
                                                           Fill="{ThemeResource NavigationViewSelectionIndicatorForeground}"
                                                           Opacity="0"
                                                           RadiusX="1.5"
                                                           RadiusY="1.5" />
                                            </Grid>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:TopNavView.ItemContainerStyle>
                    <controls:SettingsButton x:Name="Profile"
                                             Content="{CustomResource EditProfile}"
                                             Style="{StaticResource IconBadgeButtonStyle}"
                                             Click="Profile_Click">
                        <controls:SettingsButton.IconSource>
                            <icons:Profile />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Appearance"
                                             Click="Appearance_Click"
                                             Content="{CustomResource Appearance}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Appearance />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Privacy"
                                             Click="Privacy_Click"
                                             Content="{CustomResource PrivacySettings}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Privacy />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Notifications"
                                             Click="Notifications_Click"
                                             Content="{CustomResource NotificationsAndSounds}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Notifications />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Data"
                                             Click="Data_Click"
                                             Content="{CustomResource DataSettings}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Data />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="PowerSaving"
                                             Click="PowerSaving_Click"
                                             Content="{CustomResource PowerUsage}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:PowerSaving />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Folders"
                                             Click="Folders_Click"
                                             Content="{CustomResource Filters}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Folders />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Sessions"
                                             Click="Sessions_Click"
                                             Content="{CustomResource Devices}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Devices />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Language"
                                             Click="Language_Click"
                                             Content="{CustomResource Language}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Language />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton x:Name="Advanced"
                                             Click="Advanced_Click"
                                             Content="{CustomResource PrivacyAdvanced}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Advanced />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                </controls:TopNavView>

                <StackPanel x:Name="PremiumRoot"
                            x:Load="{x:Bind ViewModel.IsPremiumAvailable, Mode=OneWay}">
                    <Rectangle Fill="{ThemeResource NavigationViewItemSeparatorForeground}"
                               Margin="12,2"
                               Height="1" />

                    <controls:SettingsButton Click="Premium_Click"
                                             Content="{CustomResource TelegramPremium}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Premium />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>

                    <controls:SettingsButton Click="Stars_Click"
                                             Badge="{x:Bind ViewModel.OwnedStarCount, Mode=OneWay}"
                                             Content="{CustomResource MenuTelegramStars}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:PremiumStars />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>

                    <controls:SettingsButton Click="Business_Click"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:Business />
                        </controls:SettingsButton.IconSource>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{CustomResource TelegramBusiness}" />
                            <controls:BadgeControl Text="NEW"
                                                   VerticalAlignment="Bottom"
                                                   CornerRadius="4"
                                                   Margin="4,0,0,0"
                                                   Grid.Column="1" />
                        </Grid>
                    </controls:SettingsButton>

                    <controls:SettingsButton x:Name="PremiumGifting"
                                             Click="{x:Bind ViewModel.PremiumGifting}"
                                             Content="{CustomResource SendAGift}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:PremiumGifting />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                </StackPanel>
                <Rectangle Fill="{ThemeResource NavigationViewItemSeparatorForeground}"
                           Margin="12,2"
                           Height="1" />

                <StackPanel>
                    <controls:SettingsButton Content="{CustomResource AskAQuestion}"
                                             Click="{x:Bind ViewModel.Ask}"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:AskQ />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton Content="{CustomResource TelegramFAQ}"
                                             Click="Questions_Click"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:FAQ />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                    <controls:SettingsButton Content="{CustomResource PrivacyPolicy}"
                                             Click="PrivacyPolicy_Click"
                                             Style="{StaticResource IconBadgeButtonStyle}">
                        <controls:SettingsButton.IconSource>
                            <icons:PrivacyPolicy />
                        </controls:SettingsButton.IconSource>
                    </controls:SettingsButton>
                </StackPanel>

                <controls:VersionLabel Navigate="VersionLabel_Navigate"
                                       HorizontalContentAlignment="Left"
                                       Padding="12,8" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
