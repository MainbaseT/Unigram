<controls:ContentPopup x:Class="Telegram.Views.Premium.Popups.ChangePrivacyPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Opened="OnOpened"
                       Padding="24,24,24,0"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Border Background="{ThemeResource AccentButtonBackground}"
                    CornerRadius="48"
                    Width="96"
                    Height="96">
                <controls:AnimatedImage x:Name="Icon"
                                        AutoPlay="False"
                                        IsCachingEnabled="False"
                                        LoopCount="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FrameSize="72,72"
                                        DecodeFrameType="Logical"
                                        Width="72"
                                        Height="72" />
            </Border>

            <TextBlock x:Name="Title"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,8,0,8" />

            <TextBlock x:Name="Subtitle"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Grid.Column="1"
                       Grid.Row="2" />

            <Button x:Name="ChangeCommand"
                    Click="Change_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="0,24,0,24"
                    Grid.Row="1" />
        </StackPanel>

        <StackPanel x:Name="SubscribeRoot"
                    x:Load="False"
                    Grid.Row="1">
            <Grid Margin="0,-4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center" />
                <TextBlock Text="{CustomResource PremiumOr}"
                           Style="{StaticResource InfoCaptionTextBlockStyle}"
                           Grid.Column="1" />
                <Border BorderBrush="{ThemeResource SettingsItemBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Grid.Column="2" />
            </Grid>

            <TextBlock x:Name="SubscribeTitle"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,8,0,8" />

            <TextBlock x:Name="SubscribeSubtitle"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Grid.Column="1"
                       Grid.Row="2" />

            <Button x:Name="PurchaseCommand"
                    Click="Purchase_Click"
                    Style="{StaticResource PremiumButtonStyle}"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="0,24,0,24"
                    Grid.Row="1" />
        </StackPanel>
    </Grid>
</controls:ContentPopup>
