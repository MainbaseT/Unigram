<local:ProfileTabPage x:Class="Telegram.Views.Profile.ProfileStoriesTabPage"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:common="using:Telegram.Common"
                      xmlns:controls="using:Telegram.Controls"
                      xmlns:cells="using:Telegram.Controls.Cells"
                      xmlns:local="using:Telegram.Views.Profile"
                      mc:Ignorable="d"
                      ItemsSource="{x:Bind ViewModel.ItemsView, Mode=OneWay}">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition>
                <SlideNavigationTransitionInfo Effect="FromRight" />
            </NavigationThemeTransition>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Background="{ThemeResource SettingsPageBackground}">
        <GridView x:Name="ScrollingHost"
                  ItemClick="List_ItemClick"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  ChoosingItemContainer="OnChoosingItemContainer"
                  ContainerContentChanging="OnContainerContentChanging"
                  DragItemsStarting="OnDragItemsStarting"
                  DragItemsCompleted="OnDragItemsCompleted"
                  AllowDrop="True"
                  CanDragItems="True"
                  CanReorderItems="False"
                  common:FluidGridView.Padding="0,0,4,0"
                  common:FluidGridView.MaxLength="1008"
                  Padding="24,0,16,0">
            <common:SelectedItemsBinder.Attached>
                <common:SelectedItemsBinder SelectionMode="Auto"
                                            SelectedItems="{x:Bind ViewModel.SelectedItems}"
                                            IsItemClickEnabled="True" />
            </common:SelectedItemsBinder.Attached>
            <common:FluidGridView.Triggers>
                <common:FluidGridViewTrigger MinLength="0"
                                             RowsOrColumns="3" />
                <common:FluidGridViewTrigger MinLength="600"
                                             RowsOrColumns="4" />
                <common:FluidGridViewTrigger MinLength="800"
                                             RowsOrColumns="5" />
            </common:FluidGridView.Triggers>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaxWidth="1008" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.Template>
                <ControlTemplate TargetType="GridView">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ItemsPresenter Header="{TemplateBinding Header}"
                                        HeaderTemplate="{TemplateBinding HeaderTemplate}"
                                        HeaderTransitions="{TemplateBinding HeaderTransitions}"
                                        Footer="{TemplateBinding Footer}"
                                        FooterTemplate="{TemplateBinding FooterTemplate}"
                                        FooterTransitions="{TemplateBinding FooterTransitions}"
                                        Padding="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </GridView.Template>
            <GridView.Header>
                <StackPanel>
                    <Border x:Name="Header" />

                    <TextBlock x:Name="Hint"
                               x:Load="{x:Bind ViewModel.ShowHint, Mode=OneWay}"
                               Loaded="Hint_Loaded"
                               TextAlignment="Center"
                               Style="{StaticResource InfoCaptionTextBlockStyle}"
                               Margin="0,12,0,8" />

                    <controls:TopNavView x:Name="Navigation"
                                         Visibility="{x:Bind ViewModel.HasAlbums, Mode=OneWay}"
                                         ItemsSource="{x:Bind ViewModel.Albums}"
                                         SelectedItem="{x:Bind ViewModel.SelectedAlbum, Mode=TwoWay}"
                                         ItemContextRequested="Navigation_ItemContextRequested"
                                         AllowDrop="True"
                                         CanDragItems="True"
                                         CanReorderItems="False"
                                         DragItemsStarting="Navigation_DragItemsStarting"
                                         DragItemsCompleted="Navigation_DragItemsCompleted"
                                         DisplayMemberPath="Name"
                                         HorizontalAlignment="Center"
                                         Height="40"
                                         Margin="0,0,0,-4">
                        <controls:TopNavView.ItemContainerStyle>
                            <Style TargetType="controls:TopNavViewItem">
                                <Setter Property="HorizontalAlignment"
                                        Value="Stretch" />
                                <Setter Property="VerticalAlignment"
                                        Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalContentAlignment"
                                        Value="Center" />
                                <Setter Property="UseSystemFocusVisuals"
                                        Value="True" />
                                <Setter Property="FocusVisualMargin"
                                        Value="-3,5" />
                                <Setter Property="CornerRadius"
                                        Value="12" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="controls:TopNavViewItem">
                                            <Grid x:Name="ContentBorder"
                                                  Background="Transparent">
                                                <ContentPresenter x:Name="ContentPresenter"
                                                                  Grid.Column="1"
                                                                  Margin="12,5,12,6"
                                                                  TextWrapping="NoWrap"
                                                                  Foreground="{TemplateBinding Foreground}"
                                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  Content="{TemplateBinding Content}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                  VerticalAlignment="Center"
                                                                  AutomationProperties.AccessibilityView="Raw"
                                                                  Canvas.ZIndex="1" />
                                                <Grid x:Name="SelectionIndicatorGrid"
                                                      Margin="0,8,0,8"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch">
                                                    <Rectangle x:Name="SelectionIndicator"
                                                               Fill="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                                                               Opacity="0"
                                                               RadiusX="12"
                                                               RadiusY="12" />
                                                </Grid>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </controls:TopNavView.ItemContainerStyle>
                        <controls:TopNavView.Footer>
                            <Button Click="AddAlbum_Click"
                                    AutomationProperties.Name="{CustomResource StoriesAlbumAddAlbum}"
                                    Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                    Visibility="{x:Bind ViewModel.CanEditStories}"
                                    Style="{StaticResource ListEmptyButtonStyle}"
                                    VerticalAlignment="Center"
                                    CornerRadius="12">
                                <Grid Padding="8,3,12,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE710;"
                                               FontSize="20"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               Margin="0,0,4,-4" />
                                    <TextBlock Text="{CustomResource StoriesAlbumAddAlbum}"
                                               Grid.Column="1" />
                                </Grid>
                            </Button>
                        </controls:TopNavView.Footer>
                    </controls:TopNavView>
                </StackPanel>
            </GridView.Header>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem"
                       BasedOn="{StaticResource DefaultGridViewItemStyle}">
                    <Setter Property="Margin"
                            Value="0,4,4,0" />
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <cells:StoryCell />
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.Footer>
                <Border Height="60" />
            </GridView.Footer>
        </GridView>

        <Grid x:Name="EmptyState"
              Visibility="{x:Bind ViewModel.SelectedAlbum.IsEmpty, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border Height="{x:Bind Header.Height, Mode=OneWay}" />
            <Grid VerticalAlignment="Center"
                  MaxWidth="1000"
                  Margin="24,0"
                  Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--<controls:AnimatedImage Source="ms-appx:///Assets/Animations/MyStories.tgs"
                                        AutoPlay="True"
                                        IsCachingEnabled="False"
                                        DecodeFrameType="Logical"
                                        FrameSize="140,140"
                                        Width="140"
                                        Height="140"
                                        Margin="0,16,0,16" />-->
                <TextBlock common:TextBlockHelper.Markdown="{x:Bind ConvertEmptyTitle(ViewModel.SelectedAlbum), Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="12,0,12,0" />
                <TextBlock common:TextBlockHelper.Markdown="{x:Bind ConvertEmptySubtitle(ViewModel.SelectedAlbum), Mode=OneWay}"
                           Style="{StaticResource InfoBodyTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="12,4,12,0"
                           Grid.Row="1" />

                <Button Click="AddToAlbum_Click"
                        Visibility="{x:Bind ConvertEmptyButton(ViewModel.SelectedAlbum), Mode=OneWay}"
                        Content="{CustomResource StoriesAlbumAddToAlbum}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        Grid.Row="2" />
            </Grid>
        </Grid>

        <Grid x:Name="ManagePanel"
              Background="{ThemeResource PageSubHeaderBackgroundBrush2}"
              VerticalAlignment="Bottom"
              Margin="24,8"
              CornerRadius="15"
              MaxWidth="1000"
              Visibility="Collapsed"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="15"
                    Grid.ColumnSpan="8" />

            <controls:GlyphButton Click="{x:Bind ViewModel.UnselectStories}"
                                  CornerRadius="13,4,4,13"
                                  Glyph="&#xE711;" />

            <controls:AnimatedTextBlock Text="{x:Bind ConvertSelected(ViewModel.SelectedItems.Count), Mode=OneWay}"
                                        TextStyle="{StaticResource BaseTextBlockStyle}"
                                        VerticalAlignment="Center"
                                        Margin="0,-2,0,0"
                                        Grid.Column="1" />


            <controls:GlyphButton Glyph="{x:Bind ConvertToggleIcon(ViewModel.IsPostedToChatPage)}"
                                  Content="{x:Bind ConvertToggleText(ViewModel.IsPostedToChatPage, ViewModel.SelectedItems.Count), Mode=OneWay}"
                                  IsEnabled="{x:Bind ViewModel.CanSelectedToggleIsPinned, Mode=OneWay}"
                                  Click="{x:Bind ViewModel.ArchiveSelectedStories}"
                                  Style="{StaticResource GlyphButtonWithLabelStyle}"
                                  Grid.Column="3" />

            <controls:GlyphButton Glyph="&#xE74D;"
                                  Content="{CustomResource Delete}"
                                  IsEnabled="{x:Bind ViewModel.CanSelectedBeDeleted, Mode=OneWay}"
                                  Foreground="#df3f40"
                                  Click="{x:Bind ViewModel.DeleteSelectedStories}"
                                  Style="{StaticResource GlyphButtonWithLabelStyle}"
                                  CornerRadius="4,13,13,4"
                                  Grid.Column="4" />
        </Grid>
    </Grid>
</local:ProfileTabPage>