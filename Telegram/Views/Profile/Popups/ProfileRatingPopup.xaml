<controls:ContentPopup x:Class="Telegram.Views.Profile.Popups.ProfileRatingPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Opened="OnOpened"
                       Padding="0"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer x:Name="ScrollingHost"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">

            <StackPanel Padding="12,24">
                <Grid>
                    <Grid Background="{ThemeResource ControlFillColorDefaultBrush}"
                          CornerRadius="4"
                          Margin="12,0,12,0"
                          VerticalAlignment="Bottom">
                        <TextBlock TextAlignment="Left"
                                   FontWeight="SemiBold"
                                   Margin="8,4,8,5" />
                    </Grid>

                    <controls:PremiumProgressBar x:Name="RatingSlider"
                                                 Glyph="&#xEAB3;"
                                                 Margin="12,0" />
                    <controls:PremiumProgressBar x:Name="PendingSlider"
                                                 IsTabStop="False"
                                                 Glyph="&#xEAB3;"
                                                 Margin="12,0" />
                </Grid>

                <Grid>
                    <TextBlock x:Name="RatingInfo"
                               SizeChanged="Visual_SizeChanged"
                               Style="{StaticResource InfoCaptionTextBlockStyle}"
                               TextAlignment="Center"
                               Margin="0,4,0,8" />

                    <TextBlock x:Name="RatingPreview"
                               SizeChanged="Visual_SizeChanged"
                               Style="{StaticResource InfoCaptionTextBlockStyle}"
                               TextAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,4,0,8" />
                </Grid>

                <TextBlock Text="{CustomResource StarRatingTitle}"
                           Style="{StaticResource PopupTextBlockStyle}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,8,0,4" />
                <TextBlock x:Name="Subtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,8" />

                <StackPanel>
                    <Grid Padding="12,8,12,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border VerticalAlignment="Top"
                                Margin="0,0,12,0"
                                Width="24"
                                Height="24"
                                CornerRadius="4"
                                Grid.RowSpan="2">
                            <TextBlock Text="&#xEAD8;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20" />
                        </Border>

                        <TextBlock Text="{CustomResource StarRatingTitle1}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   VerticalAlignment="Top"
                                   Margin="0,-2,0,0"
                                   Grid.Column="1" />

                        <RichTextBlock x:Name="Description1"
                                       Style="{StaticResource InfoCaptionRichTextBlockStyle}"
                                       Grid.Column="1"
                                       Grid.Row="1" />
                    </Grid>
                    <Grid Padding="12,8,12,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border VerticalAlignment="Top"
                                Margin="0,0,12,0"
                                Width="24"
                                Height="24"
                                CornerRadius="4"
                                Grid.RowSpan="2">
                            <TextBlock Text="&#xE716;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20" />
                        </Border>

                        <TextBlock Text="{CustomResource StarRatingTitle2}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   VerticalAlignment="Top"
                                   Margin="0,-2,0,0"
                                   Grid.Column="1" />

                        <RichTextBlock x:Name="Description2"
                                       Style="{StaticResource InfoCaptionRichTextBlockStyle}"
                                       Grid.Column="1"
                                       Grid.Row="1" />
                    </Grid>
                    <Grid Padding="12,8,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border VerticalAlignment="Top"
                                Margin="0,0,12,0"
                                Width="24"
                                Height="24"
                                CornerRadius="4"
                                Grid.RowSpan="2">
                            <TextBlock Text="&#xEAD7;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20" />
                        </Border>

                        <TextBlock Text="{CustomResource StarRatingTitle3}"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   VerticalAlignment="Top"
                                   Margin="0,-2,0,0"
                                   Grid.Column="1" />

                        <RichTextBlock x:Name="Description3"
                                       Style="{StaticResource InfoCaptionRichTextBlockStyle}"
                                       Grid.Column="1"
                                       Grid.Row="1" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <controls:ScrollViewerScrim ScrollingHost="{x:Bind ScrollingHost}"
                                    Background="{ThemeResource ContentDialogBackground}" />

        <Button x:Name="LearnCommand"
                Content="{CustomResource StarRatingButtonUnderstood}"
                Click="Learn_Click"
                Style="{StaticResource AccentButtonStyle}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Margin="24,0,24,24"
                Grid.Row="1" />
    </Grid>
</controls:ContentPopup>
