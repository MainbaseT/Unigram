<local:ProfileTabPage x:Class="Telegram.Views.Profile.ProfileGiftsTabPage"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:common="using:Telegram.Common"
                      xmlns:controls="using:Telegram.Controls"
                      xmlns:messages="using:Telegram.Controls.Messages"
                      xmlns:selectors="using:Telegram.Selectors"
                      xmlns:cells="using:Telegram.Controls.Cells"
                      xmlns:local="using:Telegram.Views.Profile"
                      mc:Ignorable="d"
                      ItemsSource="{x:Bind ViewModel.ItemsView, Mode=OneWay}">

    <Grid>
        <controls:SelectGridView x:Name="ScrollingHost"
                                 IsItemClickEnabled="True"
                                 ItemClick="OnItemClick"
                                 SelectionMode="None"
                                 ChoosingItemContainer="OnChoosingItemContainer"
                                 ContainerContentChanging="OnContainerContentChanging"
                                 DragItemsStarting="OnDragItemsStarting"
                                 DragItemsCompleted="OnDragItemsCompleted"
                                 AllowDrop="True"
                                 CanDragItems="True"
                                 CanReorderItems="False"
                                 Padding="24,0,16,8"
                                 common:FluidGridView.Padding="0,0,4,0"
                                 common:FluidGridView.MaxLength="1008">
            <!--<common:SelectedItemsBinder.Attached>
                <common:SelectedItemsBinder SelectionMode="Auto"
                                            SelectedItems="{x:Bind ViewModel.SelectedItems}" />
            </common:SelectedItemsBinder.Attached>-->
            <common:FluidGridView.Triggers>
                <common:FluidGridViewTrigger MinLength="0"
                                             RowsOrColumns="2" />
                <common:FluidGridViewTrigger MinLength="360"
                                             RowsOrColumns="3" />
                <common:FluidGridViewTrigger MinLength="600"
                                             RowsOrColumns="4" />
                <common:FluidGridViewTrigger MinLength="800"
                                             RowsOrColumns="5" />
            </common:FluidGridView.Triggers>
            <GridView.Template>
                <ControlTemplate TargetType="GridView">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ItemsPresenter Header="{TemplateBinding Header}"
                                        HeaderTemplate="{TemplateBinding HeaderTemplate}"
                                        HeaderTransitions="{TemplateBinding HeaderTransitions}"
                                        Footer="{TemplateBinding Footer}"
                                        FooterTemplate="{TemplateBinding FooterTemplate}"
                                        FooterTransitions="{TemplateBinding FooterTransitions}"
                                        Padding="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </GridView.Template>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem"
                       BasedOn="{StaticResource DefaultGridViewItemStyle}">
                    <Setter Property="Margin"
                            Value="0,4,4,0" />
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.Header>
                <StackPanel>
                    <Border x:Name="Header" />

                    <controls:TopNavView x:Name="Navigation"
                                         Visibility="{x:Bind ViewModel.HasCollections, Mode=OneWay}"
                                         ItemsSource="{x:Bind ViewModel.Collections}"
                                         SelectedItem="{x:Bind ViewModel.SelectedCollection, Mode=TwoWay}"
                                         ItemContextRequested="Navigation_ItemContextRequested"
                                         AllowDrop="True"
                                         CanDragItems="True"
                                         CanReorderItems="False"
                                         DragItemsStarting="Navigation_DragItemsStarting"
                                         DragItemsCompleted="Navigation_DragItemsCompleted"
                                         DisplayMemberPath="Name"
                                         HorizontalAlignment="Center"
                                         Height="40"
                                         Margin="0,0,0,-4">
                        <controls:TopNavView.ItemContainerStyle>
                            <Style TargetType="controls:TopNavViewItem">
                                <Setter Property="HorizontalAlignment"
                                        Value="Stretch" />
                                <Setter Property="VerticalAlignment"
                                        Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalContentAlignment"
                                        Value="Center" />
                                <Setter Property="UseSystemFocusVisuals"
                                        Value="True" />
                                <Setter Property="FocusVisualMargin"
                                        Value="-3,5" />
                                <Setter Property="CornerRadius"
                                        Value="12" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="controls:TopNavViewItem">
                                            <Grid x:Name="ContentBorder"
                                                  Background="Transparent">
                                                <ContentPresenter x:Name="ContentPresenter"
                                                                  Grid.Column="1"
                                                                  Margin="12,5,12,6"
                                                                  TextWrapping="NoWrap"
                                                                  Foreground="{TemplateBinding Foreground}"
                                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  Content="{TemplateBinding Content}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                  VerticalAlignment="Center"
                                                                  AutomationProperties.AccessibilityView="Raw"
                                                                  Canvas.ZIndex="1" />
                                                <Grid x:Name="SelectionIndicatorGrid"
                                                      Margin="0,8,0,8"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch">
                                                    <Rectangle x:Name="SelectionIndicator"
                                                               Fill="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                                                               Opacity="0"
                                                               RadiusX="12"
                                                               RadiusY="12" />
                                                </Grid>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </controls:TopNavView.ItemContainerStyle>
                        <controls:TopNavView.Footer>
                            <Button Click="AddCollection_Click"
                                    AutomationProperties.Name="{CustomResource GiftsCollectionAddCollection}"
                                    Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                    Visibility="{x:Bind ViewModel.IsOwned}"
                                    Style="{StaticResource ListEmptyButtonStyle}"
                                    VerticalAlignment="Center"
                                    CornerRadius="12">
                                <Grid Padding="8,3,12,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE710;"
                                               FontSize="20"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               Margin="0,0,4,-4" />
                                    <TextBlock Text="{CustomResource GiftsCollectionAddCollection}"
                                               Grid.Column="1" />
                                </Grid>
                            </Button>
                        </controls:TopNavView.Footer>
                    </controls:TopNavView>
                </StackPanel>
            </GridView.Header>
            <GridView.Footer>
                <Border Height="60" />
            </GridView.Footer>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <cells:ReceivedGiftCell />
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaxWidth="1008" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </controls:SelectGridView>

        <Grid x:Name="EmptyState"
              Visibility="{x:Bind ViewModel.SelectedCollection.IsEmpty, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border Height="{x:Bind Header.Height, Mode=OneWay}" />
            <Grid VerticalAlignment="Center"
                  MaxWidth="1000"
                  Margin="24,0"
                  Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock common:TextBlockHelper.Markdown="{CustomResource GiftsCollectionOrganizeTitle}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="12,0,12,0" />
                <TextBlock common:TextBlockHelper.Markdown="{CustomResource GiftsCollectionOrganizeDescription}"
                           Style="{StaticResource InfoBodyTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="12,4,12,0"
                           Grid.Row="1" />

                <Button Click="AddToCollection_Click"
                        Content="{CustomResource GiftsCollectionAddToCollection}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        Grid.Row="2" />
            </Grid>
        </Grid>
    </Grid>
</local:ProfileTabPage>
