<controls:ContentPopup x:Class="Telegram.Views.Calls.Popups.ShareGroupCallPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:controls="using:Telegram.Controls"
                       mc:Ignorable="d"
                       Padding="0,0,0,0"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:ProfilePicture x:Name="Photo"
                                     Width="96"
                                     Height="96"
                                     Margin="0,24,0,8" />
            <TextBlock Text="{CustomResource GroupCallCreatedLinkTitle}"
                       Style="{StaticResource PopupTextBlockStyle}"
                       TextAlignment="Center"
                       VerticalAlignment="Bottom"
                       Grid.Row="1" />
            <TextBlock Text="{CustomResource GroupCallCreatedLinkText}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       Margin="12,0,12,0"
                       Grid.Row="2" />
        </Grid>


        <controls:SettingsPanel IsHeader="True"
                                IsFooter="True"
                                Margin="12,12,12,12"
                                Grid.Row="1">
            <controls:HeaderedControl Style="{StaticResource PopupHeaderedControlStyle}"
                                      Padding="0">
                <Grid Background="{ThemeResource SettingsItemBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Button x:Name="InviteLink"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="12,12,12,8"
                            Padding="11,5,36,6"
                            Grid.ColumnSpan="2" />

                    <controls:MoreButton x:Name="More"
                                         Click="More_ContextRequested"
                                         Glyph="&#xE996;"
                                         FontSize="16"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Margin="12,12,12,8"
                                         Width="36"
                                         Height="32"
                                         Grid.Column="1" />

                    <Button x:Name="CopyLink"
                            Click="CopyLink_Click"
                            Content="{CustomResource Copy}"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="12,4,4,12"
                            Grid.Row="1" />
                    <Button x:Name="ShareLink"
                            Click="ShareLink_Click"
                            Content="{CustomResource StickersShare}"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="4,4,12,12"
                            Grid.Column="1"
                            Grid.Row="1" />
                </Grid>
            </controls:HeaderedControl>
        </controls:SettingsPanel>
    </Grid>
</controls:ContentPopup>
