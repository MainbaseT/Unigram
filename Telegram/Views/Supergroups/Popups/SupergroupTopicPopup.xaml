<controls:ContentPopup x:Class="Telegram.Views.Supergroups.Popups.SupergroupTopicPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:local="using:Telegram.Views.Supergroups.Popups"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:drawers="using:Telegram.Controls.Drawers"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       mc:Ignorable="d"
                       PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
                       VerticalContentAlignment="Stretch"
                       Padding="24,24,24,0">

    <Grid x:Name="RootGrid"
          Margin="0,0,0,-32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock x:Name="Header"
                   Text="{CustomResource CreateTopicTitle}"
                   Style="{StaticResource BaseTextBlockStyle}"
                   Margin="0,0,0,8" />

        <TextBox x:Name="NameLabel"
                 TextChanged="NameLabel_TextChanged"
                 PlaceholderText="{CustomResource EnterTopicName}"
                 Padding="40,5,6,6"
                 Grid.Row="1" />

        <Grid Grid.Row="1">
            <controls:IdentityIcon x:Name="Identity"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="12,0" />
            <Grid x:Name="IconRoot"
                  VerticalAlignment="Center"
                  Margin="12,0">
                <Path x:Name="IconPath"
                      Data="M18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10L2.00738 10.3463L2.03275 10.7283C2.12433 11.7422 2.4066 12.7186 2.86169 13.6153L2.925 13.735L2.01493 17.3787L2.00114 17.4624L2.00131 17.5438C2.02622 17.8369 2.31127 18.0625 2.62109 17.9851L6.266 17.075L6.38669 17.1393C7.49591 17.7018 8.72679 18 10 18C14.4183 18 18 14.4183 18 10Z" />
                <TextBlock x:Name="IconText"
                           TextAlignment="Center"
                           Foreground="#FFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           Margin="2,2,0,0"
                           Width="16" />
            </Grid>

            <HyperlinkButton Click="Color_Click"
                             VerticalAlignment="Stretch"
                             Padding="0"
                             Margin="4"
                             Width="36" />
        </Grid>


        <Grid x:Name="EmojiRoot"
              Margin="-24,8,-24,0"
              Grid.Row="2">
            <drawers:TopicsEmojiDrawer x:Name="Emoji"
                                       ScrollingHostPadding="8,0,0,56" />
            <controls:ScrollViewerScrim Background="{ThemeResource ContentDialogBackground}"
                                        ScrollingHost="{x:Bind Emoji.ScrollingHost}"
                                        TopInset="0"
                                        BottomInset="56" />
        </Grid>

    </Grid>
</controls:ContentPopup>
