<controls:ContentPopup x:Class="Telegram.Views.Stars.Popups.ReceivedGiftPopup"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                       xmlns:controls="using:Telegram.Controls"
                       xmlns:messages="using:Telegram.Controls.Messages"
                       mc:Ignorable="d"
                       Padding="0,0,0,24"
                       IsDismissButtonVisible="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid x:Name="Header"
                  Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <controls:AnimatedImage x:Name="AnimatedPhoto"
                                        Width="120"
                                        Height="120"
                                        FrameSize="120,120"
                                        DecodeFrameType="Logical"
                                        IsViewportAware="True"
                                        LoopCount="1"
                                        Margin="0,-16,0,8" />

                <TextBlock x:Name="Title"
                           Text="{CustomResource GiftTelegramPremiumTitle}"
                           Style="{StaticResource PopupTextBlockStyle}"
                           TextAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="12,0"
                           Grid.Row="1" />
                <TextBlock x:Name="Subtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="24,0,24,8"
                           Grid.Row="3" />
            </Grid>
            <controls:PatternBackground x:Name="UpgradedHeader"
                                        CornerRadius="7,7,0,0"
                                        Padding="0">
                <controls:PatternBackground.Footer>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="UpgradedTitle"
                                   Text="{CustomResource GiftTelegramPremiumTitle}"
                                   Style="{StaticResource PopupTextBlockStyle}"
                                   TextAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="12,0" />

                        <messages:MessageService x:Name="UpgradedPublisher"
                                                 Click="UpgradedPublisher_Click"
                                                 Background="#22000000"
                                                 CornerRadius="12"
                                                 HorizontalAlignment="Center"
                                                 Padding="8,2,8,3"
                                                 Margin="0,0,0,8"
                                                 Visibility="Collapsed"
                                                 Grid.Row="1">
                            <TextBlock x:Name="UpgradedPublisherLabel"
                                       Foreground="#DDFFFFFF"
                                       TextAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       TextWrapping="NoWrap" />
                        </messages:MessageService>

                        <TextBlock x:Name="UpgradedSubtitle"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="#AAFFFFFF"
                                   TextAlignment="Center"
                                   Margin="24,0,24,8"
                                   Grid.Row="1" />

                        <Grid x:Name="UpgradedButtons"
                              ColumnSpacing="8"
                              Margin="8,0,8,8"
                              Visibility="Collapsed"
                              Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <controls:SettingsButton x:Name="TransferButton"
                                                     Click="TransferButton_Click"
                                                     Content="{CustomResource Gift2ActionTransfer}"
                                                     Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                                     Glyph="&#xEAC6;" />

                            <controls:SettingsButton x:Name="WearButton"
                                                     Click="WearButton_Click"
                                                     Content="{CustomResource Gift2Wear}"
                                                     Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                                     Glyph="&#xEAB3;"
                                                     Grid.Column="1" />

                            <controls:SettingsButton x:Name="ResellButton"
                                                     Click="ResellButton_Click"
                                                     Content="{CustomResource Gift2ActionResell}"
                                                     Style="{StaticResource GlyphGridBadgeButtonStyle}"
                                                     Glyph="&#xEA68;"
                                                     Grid.Column="2" />
                        </Grid>
                    </Grid>
                </controls:PatternBackground.Footer>
                <controls:AnimatedImage x:Name="UpgradedAnimatedPhoto"
                                        Width="120"
                                        Height="120"
                                        FrameSize="120,120"
                                        DecodeFrameType="Logical"
                                        IsViewportAware="True"
                                        LoopCount="1"
                                        Margin="0,12,0,8" />
            </controls:PatternBackground>

            <Grid x:Name="ResaleStarCountRoot"
                  Background="{ThemeResource MessageServiceBackgroundBrush}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Height="24"
                  CornerRadius="12"
                  Margin="8,8,0,0"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <controls:PremiumStarCount Width="18"
                                           VerticalAlignment="Top"
                                           HorizontalAlignment="Left"
                                           Margin="8,-1,4,0">
                    <controls:PremiumStarCount.Template>
                        <ControlTemplate TargetType="controls:PremiumStarCount">
                            <Viewbox>
                                <Canvas Height="24"
                                        Width="24">
                                    <Path Data="M8.90924 8.18846L11.065 3.89383C11.3142 3.39868 11.9172 3.19995 12.4089 3.44921C12.6009 3.54689 12.7559 3.7052 12.8536 3.90056L14.8914 8.04362C15.0565 8.38382 15.3832 8.61287 15.7571 8.65665L20.018 9.16864C20.5974 9.23938 21.0117 9.76821 20.9443 10.3509C20.914 10.5901 20.8062 10.8124 20.6344 10.9808L17.2627 14.3054C17.1246 14.4401 17.0606 14.6287 17.0842 14.8207L17.6467 19.3073C17.7275 19.9507 17.2728 20.5368 16.6328 20.6176C16.3903 20.6479 16.1478 20.6041 15.9322 20.4863L12.3719 18.5394C12.1125 18.3979 11.8026 18.3945 11.5433 18.5292L7.85158 20.4223C7.33286 20.6884 6.69961 20.4795 6.43351 19.9574C6.33246 19.7621 6.29878 19.5431 6.3291 19.3275L6.62214 17.2661C6.76698 16.259 7.39012 15.3832 8.29284 14.9218L12.3887 12.83C12.4965 12.7761 12.5403 12.6414 12.4864 12.5302C12.4426 12.446 12.3517 12.3955 12.2574 12.409L7.24528 13.1298C6.48067 13.2376 5.70595 13.022 5.10302 12.5302L3.43569 11.1694C2.96076 10.7821 2.88329 10.0747 3.27064 9.59642C3.45254 9.37411 3.7119 9.22927 3.99484 9.19222L8.27262 8.64318C8.54546 8.60613 8.78461 8.43771 8.90924 8.18846Z"
                                          Fill="#FFFFFF" />
                                    <Path Data="M12.7021 4.6584C12.2676 4.56072 11.8061 4.76956 11.5973 5.18723L9.43816 9.48186C9.31353 9.73112 9.07775 9.89953 8.80154 9.93659L4.52376 10.489C4.24755 10.526 3.99493 10.6608 3.81641 10.873L5.39952 12.1664C5.89804 12.574 6.54476 12.7525 7.18137 12.6616L12.1901 11.9441C12.4865 11.9037 12.7762 12.0519 12.9075 12.318C13.0793 12.6582 12.9446 13.0759 12.6044 13.251L11.2975 13.918L12.7863 13.7024C12.8806 13.6889 12.9749 13.7394 13.0153 13.8236C13.0726 13.9348 13.0254 14.0695 12.9177 14.1234L8.82175 16.2152C7.91904 16.6766 7.2959 17.5524 7.15106 18.5595L6.95906 19.8968C7.13422 20.0719 7.41042 20.1191 7.63947 20.0012L11.3244 18.1082C11.7253 17.9027 12.2002 17.9094 12.5943 18.125L16.1546 20.0719C16.2826 20.1426 16.4308 20.1696 16.5757 20.1528C16.9529 20.1056 17.2258 19.7553 17.1786 19.3679L16.6195 14.8779C16.579 14.5411 16.6936 14.2076 16.9327 13.9719L20.3044 10.6473C20.3617 10.59 20.4055 10.5227 20.4358 10.4486L16.286 9.95006C15.9121 9.90627 15.5887 9.67386 15.4203 9.33702L15.2586 9.00356C14.9184 8.85535 14.6389 8.59262 14.4705 8.25242L12.7021 4.6584Z"
                                          Fill="#FFFFFF" />
                                </Canvas>
                            </Viewbox>
                        </ControlTemplate>
                    </controls:PremiumStarCount.Template>
                </controls:PremiumStarCount>

                <TextBlock x:Name="ResaleStarCount"
                           Foreground="#FFFFFF"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           Typography.NumeralAlignment="Tabular"
                           VerticalAlignment="Center"
                           Margin="0,1,8,2"
                           Grid.Column="1" />
            </Grid>

            <Grid x:Name="DetailRoot"
                  Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid x:Name="RegularRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:TableView x:Name="TableRoot"
                                        Margin="8,8,8,0">
                        <controls:TableViewItem x:Name="FirstSale"
                                                Header="{CustomResource Gift2SoldOutSheetFirstSale}"
                                                Visibility="Collapsed" />
                        <controls:TableViewItem x:Name="LastSale"
                                                Header="{CustomResource Gift2SoldOutSheetLastSale}"
                                                Visibility="Collapsed" />
                        <controls:TableViewItem x:Name="From"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <controls:ProfilePicture x:Name="FromPhoto"
                                                         Margin="8,4,0,4"
                                                         Width="24"
                                                         Height="24" />
                                <TextBlock Margin="8,5,4,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top"
                                           Grid.Column="1">
                                    <Hyperlink Click="From_Click"
                                               UnderlineStyle="None">
                                        <Run x:Name="FromTitle" />
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem x:Name="Date"
                                                Header="{CustomResource StarsTransactionDate}" />
                        <controls:TableViewItem Header="{CustomResource Gift2Value}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <controls:PremiumStarCount Margin="8,0,0,0" />
                                <TextBlock x:Name="StarCount"
                                           Margin="4,5,8,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top"
                                           Grid.Column="1" />

                                <controls:SettingsButton x:Name="Convert"
                                                         Click="Convert_Click"
                                                         Style="{StaticResource SmallButtonStyle}"
                                                         VerticalAlignment="Center"
                                                         FontSize="11"
                                                         Padding="8,0"
                                                         CornerRadius="8"
                                                         BorderThickness="0"
                                                         Height="16"
                                                         Grid.Column="2" />
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem x:Name="Availability"
                                                Header="{CustomResource Gift2Availability}"
                                                Visibility="Collapsed" />
                    </controls:TableView>
                    <Border x:Name="CaptionRoot"
                            Background="{ThemeResource ButtonBackground}"
                            BorderBrush="{ThemeResource ButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="0,0,4,4"
                            Margin="8,0,8,0"
                            Visibility="Collapsed"
                            Grid.Row="1">
                        <controls:FormattedTextBlock x:Name="Caption"
                                                     Margin="8,5,4,6" />
                    </Border>
                </Grid>

                <Grid x:Name="UpgradedRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:TableView x:Name="UpgradedTableRoot"
                                        Margin="8,8,8,0">
                        <controls:TableViewItem Header="{CustomResource Gift2Owner}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <controls:ProfilePicture x:Name="UpgradedFromPhoto"
                                                         Margin="8,4,0,4"
                                                         Width="24"
                                                         Height="24" />
                                <TextBlock x:Name="UpgradedFromText"
                                           Margin="8,5,4,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top"
                                           Grid.Column="1">
                                    <Hyperlink Click="Owner_Click"
                                               UnderlineStyle="None">
                                        <Run x:Name="UpgradedFromTitle" />
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem Header="{CustomResource Gift2AttributeModel}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UpgradedModel"
                                           Margin="8,5,8,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top" />

                                <controls:SettingsButton x:Name="UpgradedModelRarity"
                                                         Click="UpgradedModelRarity_Click"
                                                         Style="{StaticResource SmallButtonStyle}"
                                                         VerticalAlignment="Center"
                                                         FontSize="11"
                                                         Padding="4,0"
                                                         CornerRadius="8"
                                                         BorderThickness="0"
                                                         Height="16"
                                                         Grid.Column="1" />
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem Header="{CustomResource Gift2AttributeBackdrop}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UpgradedBackdrop"
                                           Margin="8,5,8,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top" />

                                <controls:SettingsButton x:Name="UpgradedBackdropRarity"
                                                         Click="UpgradedBackdropRarity_Click"
                                                         Style="{StaticResource SmallButtonStyle}"
                                                         VerticalAlignment="Center"
                                                         FontSize="11"
                                                         Padding="4,0"
                                                         CornerRadius="8"
                                                         BorderThickness="0"
                                                         Height="16"
                                                         Grid.Column="1" />
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem Header="{CustomResource Gift2AttributeSymbol}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UpgradedSymbol"
                                           Margin="8,5,8,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top" />

                                <controls:SettingsButton x:Name="UpgradedSymbolRarity"
                                                         Click="UpgradedSymbolRarity_Click"
                                                         Style="{StaticResource SmallButtonStyle}"
                                                         VerticalAlignment="Center"
                                                         FontSize="11"
                                                         Padding="4,0"
                                                         CornerRadius="8"
                                                         BorderThickness="0"
                                                         Height="16"
                                                         Grid.Column="1" />
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem x:Name="UpgradedValueRoot"
                                                Header="{CustomResource GiftValue2}"
                                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UpgradedValue"
                                           Margin="8,5,8,6"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Top" />

                                <controls:SettingsButton x:Name="UpgradedValueRarity"
                                                         Click="UpgradedValueRarity_Click"
                                                         Glyph="{CustomResource GiftValue2LearnMore}"
                                                         Style="{StaticResource SmallButtonStyle}"
                                                         VerticalAlignment="Center"
                                                         FontSize="11"
                                                         Padding="4,0"
                                                         CornerRadius="8"
                                                         BorderThickness="0"
                                                         Height="16"
                                                         Grid.Column="1" />
                            </Grid>
                        </controls:TableViewItem>
                        <controls:TableViewItem x:Name="UpgradedQuantity"
                                                Header="{CustomResource Gift2Quantity}" />
                    </controls:TableView>
                    <Border x:Name="UpgradedCaptionRoot"
                            Background="{ThemeResource ButtonBackground}"
                            BorderBrush="{ThemeResource ButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="0,0,4,4"
                            Margin="8,0,8,0"
                            Visibility="Collapsed"
                            Grid.Row="1">
                        <controls:FormattedTextBlock x:Name="UpgradedCaption"
                                                     TextAlignment="Center"
                                                     Margin="8,5,8,6" />
                    </Border>
                </Grid>

                <Border Height="8"
                        Grid.Row="1" />

                <controls:SettingsFooter x:Name="Info"
                                         IsLink="True"
                                         Click="Visibility_Click"
                                         TextStyle="{StaticResource InfoBodyTextBlockStyle}"
                                         TextAlignment="Center"
                                         Margin="0,4,0,4"
                                         Grid.Row="2" />
            </Grid>
            <Grid x:Name="UpgradeRoot"
                  Visibility="Collapsed"
                  Grid.Row="1"
                  Grid.RowSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <controls:SettingsButton x:Name="UpgradeText1"
                                         Content="{CustomResource Gift2UpgradeFeature1Title}"
                                         Badge="{CustomResource Gift2UpgradeFeature1Text}"
                                         Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                         Glyph="&#xE76E;"
                                         Margin="12,0,12,0"
                                         IsHitTestVisible="False" />
                <controls:SettingsButton x:Name="UpgradeText2"
                                         Content="{CustomResource Gift2UpgradeFeature2Title}"
                                         Badge="{CustomResource Gift2UpgradeFeature2Text}"
                                         Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                         Glyph="&#xE76E;"
                                         Margin="12,-8,12,0"
                                         IsHitTestVisible="False"
                                         Grid.Row="1" />
                <controls:SettingsButton x:Name="UpgradeText3"
                                         Content="{CustomResource Gift2UpgradeFeature3Title}"
                                         Badge="{CustomResource Gift2UpgradeFeature3Text}"
                                         Style="{StaticResource GlyphSubbadgeBadgeButtonPopupStyle}"
                                         Glyph="&#xE76E;"
                                         Margin="12,-8,12,0"
                                         IsHitTestVisible="False"
                                         Grid.Row="2" />

                <CheckBox x:Name="KeepOriginalDetails"
                          Content="{CustomResource Gift2AddSenderName}"
                          Margin="24,0,0,0"
                          Grid.Row="3" />
            </Grid>
        </Grid>

        <Button x:Name="PurchaseCommand"
                Click="Purchase_Click"
                Style="{StaticResource AccentButtonStyle}"
                FontFamily="{StaticResource EmojiThemeFontFamilyWithSymbols}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Margin="24,8,24,0"
                Grid.Row="1">
            <Grid>
                <TextBlock x:Name="PurchaseText"
                           VerticalAlignment="Center" />
                <muxc:ProgressRing x:Name="PurchaseRing"
                                   Visibility="Collapsed"
                                   Foreground="#FFFFFF"
                                   Width="20"
                                   Height="20" />
            </Grid>
        </Button>

        <controls:MoreButton x:Name="MoreButton"
                             Click="More_ContextRequested"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,0,40,0"
                             CornerRadius="20"
                             RequestedTheme="Dark"
                             Visibility="Collapsed" />
    </Grid>
</controls:ContentPopup>
