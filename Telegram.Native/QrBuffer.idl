namespace Telegram.Native
{
    [default_interface]
    runtimeclass QrBuffer
    {
        [default_overload]
        static QrBuffer FromString(String text);
        static QrBuffer FromString(String text, Int32 minVersion, Int32 maxVersion);

        Int32 Size{ get; };
        Windows.Foundation.Collections.IVector<Boolean> Values{ get; };

        Int32 ReplaceFrom{ get; };
        Int32 ReplaceTill{ get; };
    }
}
