namespace Telegram.Native.Media
{
    [default_interface]
    runtimeclass AsyncMediaPlayerSwapChain 
    {
        AsyncMediaPlayerSwapChain();
        AsyncMediaPlayerSwapChain(Boolean create);

        Boolean IsLoaded{ get; };

        void Trim();
        void Clear();

        Windows.Foundation.Collections.IVector<String> SwapChainOptions{ get; };

        Boolean Create();
        Boolean Create(Boolean subscribe);
        void Destroy();

        void Attach(Windows.UI.Xaml.Controls.SwapChainPanel panel);
        void Attach(Windows.UI.Xaml.Controls.SwapChainPanel panel, Boolean subscribe);
        void Detach(Windows.UI.Xaml.Controls.SwapChainPanel panel);

        void UpdateSize();
        void UpdateScale();
    }
}
